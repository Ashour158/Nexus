# Plaintext template for production dotenv values.
# Do not commit a filled copy. Encrypt with:
#   scripts/sops-encrypt.sh secrets/prod.env secrets/prod.env.sops.env
#
# Docker Compose consumes the decrypted runtime file with --env-file.

DOMAIN=CHANGE_ME_fqdn
PUBLIC_IP=CHANGE_ME_public_ip
IMAGE_TAG=git-sha-required
GIT_SHA=git-sha-required
BUILT_AT=2026-01-01T00:00:00Z

POSTGRES_PASSWORD=CHANGE_ME_strong_random
REDIS_PASSWORD=CHANGE_ME_strong_random
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_random
JWT_SECRET=CHANGE_ME_at_least_32_chars
INTERNAL_SERVICE_TOKEN=CHANGE_ME_strong_random
ENCRYPTION_MASTER_KEY=CHANGE_ME_32_bytes_base64_or_platform_value
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_strong_random
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_random
MEILI_MASTER_KEY=CHANGE_ME_strong_random

APOLLO_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CHAT_EMBED_KEYS=

# Serialized encrypted backup workflow. BACKUP_PGPORT must be the direct
# managed Postgres port. Do not set PgBouncer port 6432 here.
BACKUP_AGE_RECIPIENT=REPLACE_WITH_BACKUP_AGE_PUBLIC_RECIPIENT
BACKUP_AGE_IDENTITY_FILE=/root/.config/sops/age/nexus-prod-keys.txt
BACKUP_RCLONE_DEST=CHANGE_ME_rclone_remote:nexus/prod/backups
BACKUP_LOCAL_DIR=/var/backups/nexus
BACKUP_SCRATCH_ROOT=/var/tmp/nexus-backup
BACKUP_LOCK_FILE=/var/lock/nexus-backup.lock
BACKUP_LOCAL_RETENTION_DAYS=7
BACKUP_REMOTE_RETENTION_DAYS=30
BACKUP_PGHOST=CHANGE_ME_managed_postgres_host
BACKUP_PGPORT=CHANGE_ME_direct_managed_postgres_port_not_6432
BACKUP_PGUSER=CHANGE_ME_backup_role
BACKUP_PGPASSWORD=CHANGE_ME_backup_role_password
BACKUP_VERIFY_CPUS=1.0
BACKUP_VERIFY_MEMORY=768m
CLICKHOUSE_CONTAINER=nexus-clickhouse
MEILI_URL=http://127.0.0.1:7700
MEILI_DUMPS_DIR=
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ROOT_USER=nexus

# Restore drill scratch/evidence paths. The drill prints measured RPO/RTO only
# when an operator runs it against a real encrypted artifact.
RESTORE_DRILL_SCRATCH_ROOT=/var/tmp/nexus-restore-drill
RESTORE_DRILL_REPORT_DIR=/var/log/nexus
RESTORE_DRILL_LOCK_FILE=/var/lock/nexus-restore-drill.lock
KEEP_SCRATCH=0

# Disk/capacity alerting.
CAPACITY_WARN_PERCENT=80
CAPACITY_CRITICAL_PERCENT=90
CAPACITY_INODE_WARN_PERCENT=80
CAPACITY_INODE_CRITICAL_PERCENT=90
ALERTMANAGER_URL=http://127.0.0.1:9093
CAPACITY_ALERT_WEBHOOK_REQUIRED=1
CAPACITY_ALERT_WEBHOOK_URL=CHANGE_ME_offhost_alertmanager_or_webhook_relay_url

# Periodic off-host observability evidence export. This is encrypted evidence
# shipping, not HA remote-write.
OBS_EXPORT_LOG_SINCE=30m
OBS_EXPORT_SPOOL_DIR=/var/spool/nexus-observability
OBS_EXPORT_SCRATCH_ROOT=/var/tmp/nexus-observability-export
OBS_EXPORT_LOCK_FILE=/var/lock/nexus-observability-export.lock
OBS_EXPORT_RCLONE_PREFIX=observability
OBS_EXPORT_LOCAL_RETENTION_DAYS=3
OBS_EXPORT_REMOTE_RETENTION_DAYS=14
PROMETHEUS_URL=http://127.0.0.1:9090
