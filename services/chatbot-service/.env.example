# -- Required ---------------------------------------------------------------
PORT=3017
NODE_ENV=development
CHATBOT_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_chatbot
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=chatbot-service

# -- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -- Optional ---------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=

# -- Public web-chat tenant resolution --------------------------------------
# The public POST /api/v1/chat/session endpoint resolves which tenant a visitor
# session belongs to. To prevent an anonymous caller from opening sessions (and
# emitting lead/timeline events) under an arbitrary tenant, a bare caller-supplied
# `tenantId` is NOT trusted in production.
#
# Recommended (production): map issued embed keys to tenant ids. When set, the
# tenant is derived ONLY from a matching embed key; a bare tenantId is ignored.
#   CHAT_EMBED_KEYS=pubkey_abc123:tenantA,pubkey_def456:tenantB
CHAT_EMBED_KEYS=
#
# Dev-only escape hatch: when NO embed-key map is configured, a bare tenantId is
# honoured automatically in non-production (NODE_ENV !== production). To allow it
# in a production-like environment (NOT recommended), set this flag to true.
#   CHAT_ALLOW_UNVERIFIED_TENANT=true
