NODE_ENV=development
PORT=3003
LOG_LEVEL=info

# Postgres — uses nexus_notifications database.
DATABASE_URL=postgres://nexus:nexus@localhost:5432/nexus_notifications?schema=public

# JWT secret — shared with the auth-service (HS256).
JWT_SECRET=change-me-to-a-long-random-secret-32chars-min

CORS_ORIGINS=http://localhost:3100,http://localhost:3000

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=notification-service

# CRM service — used for enrichment lookups (owner emails, deal detail).
CRM_SERVICE_URL=http://localhost:3001/api/v1
AUTH_SERVICE_URL=http://localhost:3010/api/v1

# Email (SMTP). If unset, email channel falls back to a no-op with a warning.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Nexus CRM <no-reply@nexuscrm.local>"
