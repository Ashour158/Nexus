generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/planning-client"
}

datasource db {
  provider = "postgresql"
  url      = env("PLANNING_DATABASE_URL")
}

model QuotaPlan {
  id        String        @id @default(cuid())
  tenantId  String
  name      String
  year      Int
  quarter   Int?
  type      QuotaType     @default(REVENUE)
  currency  String        @default("USD")
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  targets   QuotaTarget[]

  @@index([tenantId, year])
  @@unique([id, tenantId])
}

model QuotaTarget {
  id          String    @id @default(cuid())
  planId      String
  plan        QuotaPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  tenantId    String
  ownerId     String
  targetValue Decimal   @db.Decimal(18, 2)
  currency    String    @default("USD")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([planId, ownerId])
  @@index([tenantId, ownerId])
  @@unique([id, tenantId])
}

model ForecastSubmission {
  id             String           @id @default(cuid())
  tenantId       String
  ownerId        String
  period         String
  commitAmount   Decimal          @db.Decimal(18, 2)
  bestCaseAmount Decimal          @db.Decimal(18, 2)
  pipelineAmount Decimal          @db.Decimal(18, 2)
  commentary     String?
  submittedAt    DateTime         @default(now())
  reviews        ForecastReview[]

  @@unique([tenantId, ownerId, period])
  @@index([tenantId, ownerId, period])
  @@unique([id, tenantId])
}

model ForecastReview {
  id             String               @id @default(cuid())
  submissionId   String
  submission     ForecastSubmission   @relation(fields: [submissionId], references: [id])
  reviewerId     String
  // Lifecycle: SUBMITTED → APPROVED | ADJUSTED. Defaults to APPROVED so the
  // pre-existing `reviewForecast` (which just records a review) keeps working.
  status         ForecastReviewStatus @default(APPROVED)
  adjustedCommit Decimal?             @db.Decimal(18, 2)
  adjustedBest   Decimal?             @db.Decimal(18, 2)
  note           String?
  reviewedAt     DateTime             @default(now())
  updatedAt      DateTime             @updatedAt @default(now())
}

enum ForecastReviewStatus {
  SUBMITTED
  APPROVED
  ADJUSTED
}

// ─── Prompt 31 — Forecast Manager Override ───────────────────────────────────

model ForecastOverride {
  id              String   @id @default(cuid())
  tenantId        String
  periodKey       String
  repId           String
  managerId       String
  originalValue   Decimal  @db.Decimal(18, 2)
  overrideValue   Decimal  @db.Decimal(18, 2)
  note            String?
  scopePipelineId String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, periodKey, repId, scopePipelineId])
  @@index([tenantId, periodKey])
  @@index([tenantId, repId])
  @@unique([id, tenantId])
}

enum QuotaType {
  REVENUE
  DEAL_COUNT
  ACTIVITY_COUNT
  NEW_LOGOS
}

// ─── Event-driven forecast roll-up (deals-service deal.* events) ─────────────
//
// `ForecastAggregate` is the live, per-owner/per-period forecast maintained by
// the deals consumer. It is derived state: it is always recomputed as the SUM
// over `DealForecastState` rows for that owner/period, which makes the consumer
// fully idempotent and safe under restart / event replay.

model ForecastAggregate {
  id              String   @id @default(cuid())
  tenantId        String
  ownerId         String
  period          String
  // Forecast categories, in dollars, over currently-open deals for the period.
  commitAmount    Decimal  @default(0) @db.Decimal(18, 2)
  bestCaseAmount  Decimal  @default(0) @db.Decimal(18, 2)
  pipelineAmount  Decimal  @default(0) @db.Decimal(18, 2)
  // Realized attainment inputs.
  closedWonAmount Decimal  @default(0) @db.Decimal(18, 2)
  openDealCount   Int      @default(0)
  wonDealCount    Int      @default(0)
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, ownerId, period])
  @@index([tenantId, period])
  @@unique([id, tenantId])
}

model DealForecastState {
  id        String   @id @default(cuid())
  tenantId  String
  dealId    String
  ownerId   String
  period    String
  amount    Decimal  @default(0) @db.Decimal(18, 2)
  // commit | best_case | pipeline | won | lost
  category  String   @default("pipeline")
  updatedAt DateTime @updatedAt

  @@unique([tenantId, dealId])
  @@index([tenantId, ownerId, period])
  @@unique([id, tenantId])
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}