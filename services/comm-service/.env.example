# -- Required ---------------------------------------------------------------
PORT=3009
NODE_ENV=development
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_comm
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=comm-service

# -- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# Redis - must include password if Redis is configured with requirepass
REDIS_URL=redis://:nexus@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=nexus

# -- Optional ---------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=
