generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/workflow-client"
}

datasource db {
  provider = "postgresql"
  url      = env("WORKFLOW_DATABASE_URL")
}

model WorkflowTemplate {
  id                String              @id @default(cuid())
  tenantId          String
  name              String
  description       String?
  trigger           String
  triggerConditions Json                @default("{}")
  nodes             Json
  edges             Json
  isActive          Boolean             @default(false)
  version           Int                 @default(1)
  // Schedule bookkeeping (used only when trigger === 'schedule'). Tracked so a
  // service restart cannot double-fire a due schedule.
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  executions        WorkflowExecution[]
  versions          WorkflowVersion[]

  @@index([tenantId])
  @@index([tenantId, trigger, isActive])
  @@index([trigger, isActive, nextRunAt])
  @@unique([id, tenantId])
}

model WorkflowVersion {
  id           String           @id @default(cuid())
  tenantId     String
  workflowId   String
  workflow     WorkflowTemplate @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  version      Int
  nodes        Json
  edges        Json
  name         String
  description  String?
  createdBy    String
  createdAt    DateTime         @default(now())

  @@index([tenantId, workflowId])
  @@unique([workflowId, version])
  @@unique([id, tenantId])
}

model WorkflowExecution {
  id             String                @id @default(cuid())
  tenantId       String
  workflowId     String
  workflow       WorkflowTemplate      @relation(fields: [workflowId], references: [id])
  triggerType    String
  triggerPayload Json
  status         ExecutionStatus       @default(RUNNING)
  currentNodeId  String?
  resumeAt       DateTime?
  startedAt      DateTime              @default(now())
  completedAt    DateTime?
  error          String?
  steps          WorkflowStep[]
  parentForkId   String?
  parentExecId   String?
  parent         WorkflowExecution?    @relation("BranchChildren", fields: [parentExecId], references: [id], onDelete: SetNull)
  branchChildren WorkflowExecution[]   @relation("BranchChildren")
  forkTrackers   WorkflowForkTracker[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, status, resumeAt])
  @@index([status, resumeAt])
  @@index([parentExecId])
  @@unique([id, tenantId])
}

model WorkflowForkTracker {
  id             String            @id @default(cuid())
  executionId    String
  execution      WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  forkNodeId     String
  joinNodeId     String
  branchNodeIds  String[]
  completedIds   String[]         @default([])
  createdAt      DateTime         @default(now())

  @@index([executionId, forkNodeId])
}

model WorkflowStep {
  id          String            @id @default(cuid())
  executionId String
  execution   WorkflowExecution @relation(fields: [executionId], references: [id])
  nodeId      String
  nodeType    String
  status      StepStatus        @default(PENDING)
  input       Json              @default("{}")
  output      Json?
  error       String?
  startedAt   DateTime          @default(now())
  completedAt DateTime?

  @@index([executionId])
}

enum ExecutionStatus {
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum StepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

model Journey {
  id            String            @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  status        JourneyStatus     @default(DRAFT)
  entryTrigger  String            // FORM_SUBMIT, TAG_ADDED, MANUAL, API
  entryConfig   Json              @default("{}") // segment rules, form id, tag name
  nodes         Json              // React Flow compatible node array
  edges         Json              // React Flow compatible edge array
  settings      Json              @default("{}") // exit conditions, re-entry rules
  version       Int               @default(1)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  enrollments   JourneyEnrollment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@unique([id, tenantId])
}

model JourneyEnrollment {
  id          String        @id @default(cuid())
  tenantId    String
  journeyId   String
  journey     Journey       @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  contactId   String
  currentNodeId String?
  status      EnrollmentStatus @default(ACTIVE)
  enteredAt   DateTime      @default(now())
  exitedAt    DateTime?
  exitReason  String?       // COMPLETED, GOAL_REACHED, UNSUBSCRIBED, ERROR
  metadata    Json          @default("{}")

  @@index([tenantId])
  @@index([journeyId, status])
  @@index([contactId])
  @@unique([journeyId, contactId], name: "journeyId_contactId")
}

enum JourneyStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  EXITED
}

// ─── CommandCenter — Customer Journey Orchestration ─────────────────────────
//
// Higher-level than WorkflowTemplate (one-off automations): a CommandJourney is
// a long-running, per-record, step-based orchestration. Records (lead / contact
// / account / deal) are enrolled and progress through ordered steps over time
// and events. Named `Command*` to stay additive alongside the existing
// marketing-flavoured Journey model (contact-only, nodes/edges) which is left
// untouched.

model CommandJourney {
  id           String                     @id @default(cuid())
  tenantId     String
  name         String
  description  String?
  entityType   String                     // lead | contact | account | deal
  status       CommandJourneyStatus       @default(DRAFT)
  // { event?: string, conditions?: [{ field, operator, value }], match?: 'all'|'any' }
  entryTrigger Json                       @default("{}")
  // Ordered steps: [{ id, type, config, nextStepId?, branches?: [{condition,nextStepId}] }]
  steps        Json                       @default("[]")
  // Optional early-exit rule: { conditions?: [...], match?: 'all'|'any' }
  exitCriteria Json?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  enrollments  CommandJourneyEnrollment[]

  @@index([tenantId])
  @@index([tenantId, status])
  // entryTrigger event matching: scan ACTIVE journeys for a tenant
  @@index([tenantId, entityType, status])
  @@unique([id, tenantId])
}

model CommandJourneyEnrollment {
  id            String                       @id @default(cuid())
  tenantId      String
  journeyId     String
  journey       CommandJourney               @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  entityType    String
  entityId      String
  currentStepId String?
  status        CommandEnrollmentStatus      @default(ACTIVE)
  context       Json                         @default("{}")
  enteredAt     DateTime                     @default(now())
  resumeAt      DateTime?
  lastStepAt    DateTime?
  error         String?
  updatedAt     DateTime                     @updatedAt

  // A record is never double-enrolled in the same journey.
  @@unique([tenantId, journeyId, entityId])
  // Scheduler: pick up ACTIVE enrollments whose resumeAt is due.
  @@index([status, resumeAt])
  @@index([tenantId, journeyId])
  @@index([tenantId, entityType, entityId])
}

enum CommandJourneyStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CommandEnrollmentStatus {
  ACTIVE
  COMPLETED
  EXITED
  FAILED
}

// ─── Automation Rules — cross-module declarative automation ─────────────────
//
// A simpler, admin-configurable layer than WorkflowTemplate. One row = one rule:
// "when <triggerEvent> happens on <module> (with optional AND conditions), run
// <actions>". Evaluated by the Kafka automation consumer against every relevant
// domain event; matched rules execute their actions via the existing engine node
// handlers. Each firing records an AutomationRuleRun for audit/idempotency.

model AutomationRule {
  id           String              @id @default(cuid())
  tenantId     String
  name         String
  description  String?
  module       String              // lead | contact | account | deal | quote | ticket | campaign | invoice | ...
  triggerEvent String              // e.g. 'deal.created', 'deal.stage_changed', 'ticket.sla.breached'
  // Trigger classification (Zoho Workflow-Rule parity, WF-DEPTH):
  //   record_action → fire on the domain event (default, existing behaviour)
  //   field_update  → fire only when triggerConfig.fieldUpdate matched (a field
  //                   changed to/from a value on an update event)
  //   date_time     → do NOT fire instantly; (re)schedule the rule's actions
  //                   relative to a date field on the record (see dateTriggers)
  //   scheduled     → authored as a delayed-action-first rule (still gated by the
  //                   trigger event; scheduledActions carry the delayed work)
  triggerType  String              @default("record_action")
  // Extra trigger config keyed by triggerType, e.g.
  //   field_update → { fieldUpdate: { field, from?, to? } }
  triggerConfig Json               @default("{}")
  // [{ field, operator, value }] — AND-combined, evaluated against the event payload
  conditions   Json                @default("[]")
  // [{ type, config }] — type ∈ engine action types (SEND_NOTIFICATION/CREATE_TASK/…)
  actions      Json                @default("[]")
  // Time-delayed actions (WF-DEPTH): [{ delay: { value, unit }, action: { type, config } }]
  // Each fires `delay` after the trigger via a ScheduledAutomationAction, re-checked
  // against the rule criteria at fire time.
  scheduledActions Json            @default("[]")
  isActive     Boolean             @default(true)
  runCount     Int                 @default(0)
  lastRunAt    DateTime?
  createdBy    String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  runs         AutomationRuleRun[]
  versions     AutomationRuleVersion[]
  scheduled    ScheduledAutomationAction[]
  dateTriggers DateBasedTrigger[]

  @@index([tenantId, module, triggerEvent])
  @@index([tenantId, isActive])
  @@unique([id, tenantId])
}

// A single time-delayed / date-relative action queued for future execution
// (WF-DEPTH). Produced by an automation rule's `scheduledActions` (delay after a
// trigger) or by a `DateBasedTrigger` (relative to a record date field). A poller
// (`startScheduledActionPoller`) picks up rows whose `runAt` is due, RE-CHECKS the
// owning rule's criteria against the captured payload snapshot, and — if still
// matching — executes the action through the SAME engine node handlers as an
// instant action. If the rule is gone/inactive or no longer matches, the row is
// CANCELLED instead of fired.
model ScheduledAutomationAction {
  id        String         @id @default(cuid())
  tenantId  String
  ruleId    String
  rule      AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  // The CRM record this action targets (resolved from the trigger payload).
  entityId  String
  module    String
  // Source domain-event id that scheduled this action (traceability).
  eventId   String
  // 'delay' (rule.scheduledActions) | 'date' (DateBasedTrigger).
  origin    String         @default("delay")
  // Stable idempotency key so the same (event,action) is never double-queued and a
  // date trigger re-schedules (updates runAt) rather than duplicating on re-fire.
  dedupeKey String         @unique
  // When the action becomes due.
  runAt     DateTime
  // { type, config } — one automation action (same shape as rule.actions[i]).
  action    Json
  // Snapshot of the trigger payload — used both to re-check the rule criteria at
  // fire time and as the execution context payload.
  payload   Json           @default("{}")
  status    String         @default("PENDING") // PENDING | FIRING | DONE | CANCELLED | FAILED
  error     String?
  firedAt   DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([status, runAt])
  @@index([tenantId, ruleId])
  @@index([tenantId, module, entityId])
}

// Date/time trigger definition (WF-DEPTH): "fire N units before/after a date
// field on the record", e.g. "3 days before Deal.expectedCloseDate". When a
// record event for `module` carries `dateField`, the automation service computes
// the fire time and (re)schedules the owning rule's actions as
// ScheduledAutomationAction rows. Stored as child rows of a rule so the visual
// builder can author several date anchors per rule.
model DateBasedTrigger {
  id        String         @id @default(cuid())
  tenantId  String
  ruleId    String
  rule      AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  module    String
  dateField String         // payload field holding the anchor date (e.g. 'expectedCloseDate')
  offset    Int            @default(0)      // magnitude, in `unit`s
  unit      String         @default("days") // minutes | hours | days
  direction String         @default("before") // before | after
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([tenantId, ruleId])
  @@index([tenantId, module, isActive])
}

// Immutable snapshot of a rule's authored state (conditions + actions + meta),
// written on every create/update/rollback. Powers version history + rollback
// (AU-3): a mis-authored edit can be reverted to any prior committed state.
model AutomationRuleVersion {
  id        String         @id @default(cuid())
  tenantId  String
  ruleId    String
  rule      AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  version   Int            // monotonic per rule, starting at 1
  // { name, description, module, triggerEvent, conditions, actions, isActive }
  snapshot  Json
  // Free-text note: 'create' | 'update' | 'rollback:<n>' | 'pre-rollback'
  reason    String?
  createdBy String
  createdAt DateTime       @default(now())

  @@unique([ruleId, version])
  @@index([tenantId, ruleId])
  @@index([ruleId, version])
}

model AutomationRuleRun {
  id        String         @id @default(cuid())
  tenantId  String
  ruleId    String
  rule      AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  eventId   String         // source domain-event id — dedupe key
  status    String         @default("RUNNING") // RUNNING | SUCCESS | PARTIAL | FAILED | SKIPPED
  error     String?
  ranAt     DateTime       @default(now())

  // One run per (rule, event) — the idempotency guard for the consumer.
  @@unique([ruleId, eventId])
  @@index([tenantId, ruleId])
  @@index([ruleId, ranAt])
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}

// ─── SLA Engine ─────────────────────────────────────────────────────────────

model SlaDefinition {
  id            String       @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  entityType    String       // deal, lead, ticket, etc.
  stageId       String?      // optional: specific pipeline stage
  condition     Json         @default("{}") // JSON filter conditions
  timeLimitHours Int         @default(24)
  businessHoursOnly Boolean  @default(true)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  breaches      SlaBreach[]

  @@index([tenantId])
  @@index([tenantId, entityType, isActive])
  @@unique([id, tenantId])
}

model SlaBreach {
  id             String        @id @default(cuid())
  tenantId       String
  slaId          String
  sla            SlaDefinition @relation(fields: [slaId], references: [id], onDelete: Cascade)
  entityId       String        // the deal/lead/ticket ID that breached
  entityType     String
  status         String        @default("BREACHED") // BREACHED, ESCALATED, RESOLVED
  breachedAt     DateTime      @default(now())
  resolvedAt     DateTime?
  escalationLevel Int          @default(1)
  metadata       Json          @default("{}")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([slaId, entityId])
  @@unique([id, tenantId])
}

// ─── Escalation Rules (Zoho "Escalation Rules" — time-based, tiered) ─────────
//
// A tiered, time-based escalation ladder for a module. When a record needs
// watching (e.g. an unanswered case / an unattended high-value deal), an
// EscalationInstance is opened; a poller walks it up the `tiers` ladder, firing
// each tier's action at its `afterMinutes` mark (measured from `startedAt`).
// Resolving the instance (record replied / closed) stops the ladder.
model EscalationRule {
  id                String               @id @default(cuid())
  tenantId          String
  module            String               // deal | lead | ticket | activity | ...
  name              String
  // Optional [{ field, operator, value }] filter — advisory metadata used when an
  // instance is opened (the caller/consumer decides eligibility). AND-combined.
  criteria          Json?
  // Ordered ladder: [{ afterMinutes, action: NOTIFY|REASSIGN|SET_FIELD|CREATE_TASK,
  //                    target, params }]. `afterMinutes` is measured from startedAt.
  tiers             Json                 @default("[]")
  // When true, tier fire times are shifted into the next business-hours window.
  businessHoursOnly Boolean              @default(false)
  isActive          Boolean              @default(true)
  createdBy         String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  instances         EscalationInstance[]

  @@index([tenantId, module, isActive])
  @@unique([id, tenantId])
}

// A single record's progress up an EscalationRule ladder. `nextFireAt` is the due
// time of `currentTier`; the poller fires it, advances the tier, and marks
// COMPLETED after the last tier. RESOLVED = stopped early (record replied/closed).
model EscalationInstance {
  id          String         @id @default(cuid())
  tenantId    String
  ruleId      String
  rule        EscalationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  module      String
  recordId    String
  // Snapshot of the record used to resolve action targets/fields at fire time.
  recordData  Json           @default("{}")
  startedAt   DateTime       @default(now())
  currentTier Int            @default(0)
  nextFireAt  DateTime
  resolvedAt  DateTime?
  status      String         @default("ACTIVE") // ACTIVE | RESOLVED | COMPLETED
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, nextFireAt])
  @@index([tenantId, module, recordId])
  @@index([tenantId, ruleId])
  @@unique([id, tenantId])
}

// ─── Scoring Rules Engine (configurable record scoring) ─────────────────────
//
// Admin-configured scoring for leads/deals/contacts/accounts. Each rule carries
// conditions with positive/negative points; the engine sums the points of matched
// conditions into a RecordScore. Recomputed on demand or automatically when a
// relevant record event arrives.
model ScoringRule {
  id         String   @id @default(cuid())
  tenantId   String
  module     String   // lead | deal | contact | account
  name       String
  // [{ field, operator, value, points }] — each matched condition adds `points`
  // (may be negative). Uses the same operator set as automation-rule conditions.
  conditions Json     @default("[]")
  isActive   Boolean  @default(true)
  createdBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, module, isActive])
  @@unique([id, tenantId])
}

// Materialised score for a single record (one row per tenant+module+record).
model RecordScore {
  id        String   @id @default(cuid())
  tenantId  String
  module    String
  recordId  String
  score     Int      @default(0)
  // [{ ruleId, ruleName, field, operator, value, points }] — the matched
  // conditions that contributed to `score`.
  breakdown Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, module, recordId])
  @@index([tenantId, module])
}

// ─── Threshold / Big-Deal Alerts ────────────────────────────────────────────
//
// Fire a notification to roles/users when a record field crosses a threshold
// (e.g. Deal.amount >= 100000). Evaluated on record events; deduped so it fires
// once per crossing (see ThresholdAlertState) rather than on every subsequent
// event while the record remains over the line.
model ThresholdAlert {
  id          String               @id @default(cuid())
  tenantId    String
  module      String
  name        String
  field       String
  operator    String               // eq | neq | gt | gte | lt | lte | contains | ...
  value       Json
  notifyRoles String[]             @default([])
  notifyUsers String[]             @default([])
  isActive    Boolean              @default(true)
  createdBy   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  states      ThresholdAlertState[]

  @@index([tenantId, module, isActive])
  @@unique([id, tenantId])
}

// Last-known crossing state per (alert, record) — the fired-marker that makes a
// threshold alert fire once per crossing (edge-triggered), not on every event.
model ThresholdAlertState {
  id         String         @id @default(cuid())
  tenantId   String
  alertId    String
  alert      ThresholdAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  recordId   String
  crossed    Boolean        @default(false)
  lastFiredAt DateTime?
  updatedAt  DateTime       @updatedAt

  @@unique([alertId, recordId])
  @@index([tenantId, alertId])
}