generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/blueprint-client"
}

datasource db {
  provider = "postgresql"
  url      = env("BLUEPRINT_DATABASE_URL")
}

model Playbook {
  id          String          @id @default(cuid())
  tenantId    String
  name        String
  description String?
  pipelineId  String?
  isActive    Boolean         @default(true)
  version     Int             @default(1)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  stages      PlaybookStage[]

  @@index([tenantId])
  @@unique([id, tenantId])
}

model PlaybookStage {
  id             String   @id @default(cuid())
  tenantId       String
  playbookId     String
  playbook       Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  stageId        String
  stageName      String
  position       Int
  entryActions   Json     @default("[]")
  exitCriteria   Json     @default("[]")
  requiredFields String[] @default([])
  talkingPoints  String[] @default([])
  resources      Json     @default("[]")

  @@unique([playbookId, stageId])
  @@index([playbookId])
  @@index([tenantId])
  @@unique([id, tenantId])
}

model DealTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  pipelineId  String?
  fields      Json     @default("[]")
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@unique([id, tenantId])
}

model StageTransitionRule {
  id          String   @id @default(cuid())
  tenantId    String
  pipelineId  String
  fromStageId String
  toStageId   String
  rules       Json
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, pipelineId, fromStageId, toStageId])
  @@unique([id, tenantId])
}

/// Zoho-Blueprint-parity transition definition. A named edge between two
/// PlaybookStages carrying Before / During / After semantics plus optional SLA.
model BlueprintTransition {
  id               String   @id @default(cuid())
  tenantId         String
  playbookId       String
  name             String
  fromStageId      String
  toStageId        String
  /// { criteria: Rule[], allowedRoles: string[] } — who may run it + entry gate.
  beforeConditions Json     @default("{}")
  /// { mandatoryFields: string[], mandatoryActions: {id,label}[], checklist: {id,label,required?}[], message?: string }
  duringConfig     Json     @default("{}")
  /// { fieldUpdates: {field,value}[], alerts: {userId?,roles?,title,body}[], tasks: {subject,ownerId?,dueInHours?}[], functions: {name,payload?}[] }
  afterActions     Json     @default("{}")
  /// Minutes the record may sit in `toStageId` before the SLA is breached.
  slaMinutes       Int?
  /// { notifyUserIds?: string[], notifyRoles?: string[], reassignTo?: string, message?: string, alerts?: {...}[] }
  escalationConfig Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
  @@index([playbookId])
  @@index([playbookId, fromStageId])
  @@unique([id, tenantId])
}

/// Live position of a record (any module) inside a playbook, plus its transition
/// history and the SLA clock for the stage it currently occupies.
model BlueprintRecordState {
  id              String    @id @default(cuid())
  tenantId        String
  module          String
  recordId        String
  playbookId      String
  currentStageId  String
  /// Append-only array of { fromStageId, toStageId, transitionId, byUserId, at, data }.
  history         Json      @default("[]")
  slaTransitionId String?
  slaDueAt        DateTime?
  slaBreached     Boolean   @default(false)
  slaBreachedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, module, recordId])
  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([slaBreached, slaDueAt])
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}