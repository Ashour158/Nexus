# Apollo Router Environment Variables

# Apollo Studio Configuration (optional)
APOLLO_KEY=your-apollo-key
APOLLO_GRAPH_REF=nexus-crm@current

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3100,https://nexus-crm.com

# JWT Configuration
JWT_SECRET=nexus-graphql-secret-key-min-32-chars

# Rate Limiting
RATE_LIMIT_CAPACITY=1000
RATE_LIMIT_INTERVAL=60s

# Telemetry
PROMETHEUS_ENABLED=true
JAEGER_ENABLED=true
JAEGER_ENDPOINT=http://jaeger:14268/api/traces