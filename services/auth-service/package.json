{
    "name": "@nexus/auth-service",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc --project tsconfig.build.json",
        "start": "node dist/index.js",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate deploy",
        "db:studio": "prisma studio",
        "db:seed": "tsx prisma/seed.ts"
    },
    "dependencies": {
        "@apollo/subgraph": "^2.13.3",
        "@fastify/rate-limit": "^9.1.0",
        "@fastify/request-context": "^5.1.0",
        "@fastify/swagger": "^9.0.0",
        "@fastify/swagger-ui": "^5.0.0",
        "@nexus/cache": "workspace:*",
        "@nexus/kafka": "workspace:*",
        "@nexus/outbox": "workspace:*",
        "@nexus/security": "workspace:*",
        "@nexus/service-utils": "workspace:*",
        "@nexus/shared-types": "workspace:*",
        "@nexus/validation": "workspace:*",
        "@prisma/client": "^5.15.0",
        "dotenv": "^16.4.5",
        "fastify": "^4.28.1",
        "graphql": "^16.13.2",
        "graphql-yoga": "^5.21.0",
        "jose": "^5.9.3",
        "otpauth": "^9.3.6",
        "passport": "^0.7.0",
        "qrcode": "^1.5.4",
        "@node-saml/passport-saml": "^4.0.5",
        "prom-client": "^15.1.0",
        "dataloader": "^2.2.3",
        "zod": "^3.23.8"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    },
    "devDependencies": {
        "@types/node": "^20.14.9",
        "@types/supertest": "^7.2.0",
        "msw": "^2.3.1",
        "prisma": "^5.22.0",
        "supertest": "^7.2.2",
        "tsx": "^4.16.0",
        "typescript": "^5.5.3",
        "vitest": "^1.6.0"
    }
}
