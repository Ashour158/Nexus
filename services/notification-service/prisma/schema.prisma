generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/.prisma/notification-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("NOTIFICATION_DATABASE_URL")
}

/// Notification fan-out record written by the in-app channel and consumed by
/// the web client via `GET /notifications`.
model Notification {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  type        String
  title       String
  body        String
  entityType  String?
  entityId    String?
  actionUrl   String?
  channel     String    @default("IN_APP")
  isRead      Boolean   @default(false)
  readAt      DateTime?
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now())

  @@index([tenantId, userId, isRead, createdAt])
  @@index([tenantId, entityType, entityId])
  @@unique([id, tenantId])
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}