generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/auth-client"
}

datasource db {
  provider = "postgresql"
  // Same variable as runtime (`requireEnv(['DATABASE_URL', ...])`) and `services/auth-service/.env.example`.
  url      = env("AUTH_DATABASE_URL")
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  isActive    Boolean  @default(true)
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  roles       Role[]
  apiKeys     ApiKey[]
}

model User {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email           String
  emailVerified   Boolean       @default(false)
  keycloakId      String        @unique
  passwordHash    String?       // For local auth (bcrypt/scrypt)
  mustChangePassword Boolean    @default(false) // set on invite → forced change on first login
  firstName       String
  lastName        String
  avatarUrl       String?
  phone           String?
  locale          String        @default("en")
  timezone        String        @default("UTC")
  isActive        Boolean       @default(true)
  lastLoginAt     DateTime?
  ssoProvider     String?
  bookingToken    String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  profile         UserProfile?
  userRoles       UserRole[]
  sessions        Session[]
  auditLogs       AuditLog[]
  passwordResets  PasswordReset[]
  mfaConfiguration MfaConfiguration?
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, createdAt])
  @@unique([id, tenantId])
}

model GdprErasureRequest {
  id            String   @id @default(uuid())
  tenantId      String
  subjectEmail  String?
  subjectId     String?
  requestedBy   String
  status        String   @default("PENDING")
  completedAt   DateTime?
  servicesAcked String[] @default([])
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@unique([id, tenantId])
}

model SsoConfiguration {
  tenantId     String   @id
  provider     String   @default("saml")
  entryPoint   String
  issuer       String
  certificate  String
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([tenantId, provider])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model Role {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  permissions Json         @default("[]")
  isSystem    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userRoles   UserRole[]
  @@unique([tenantId, name])
  @@unique([id, tenantId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, roleId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  mfaVerified  Boolean  @default(false)
  createdAt    DateTime @default(now())
  @@index([userId])
  @@index([expiresAt])
}

model MfaConfiguration {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret        String   // Base32-encoded TOTP secret (encrypted at application layer)
  method        String   @default("TOTP") // TOTP, SMS, EMAIL
  backupCodes   Json     @default("[]")   // Array of hashed backup codes
  enabledAt     DateTime?
  lastVerifiedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([userId])
}

model ApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String    @unique
  keyPrefix   String
  scopes      Json      @default("[]")
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  @@index([tenantId])
  @@unique([id, tenantId])
}

model IpRestriction {
  id          String   @id @default(cuid())
  tenantId    String
  type        String   // ALLOW or BLOCK
  cidr        String   // e.g., "192.168.1.0/24" or "10.0.0.1"
  description String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([tenantId])
  @@index([tenantId, type])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  resource   String
  resourceId String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  @@index([tenantId])
  @@index([tenantId, resource, resourceId])
  @@index([tenantId, createdAt])
  @@unique([id, tenantId])
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}

model UserProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId          String
  bio               String?
  dateOfBirth       DateTime?
  nationality       String?
  personalEmail     String?
  personalPhone     String?
  jobTitle          String?
  department        String?
  // Org-structure FKs (CRM system-control layer). `department` (free-text) is
  // kept for backward compatibility; `departmentId`/`levelId` are the
  // structured references. `managerId` remains the reporting-line source.
  departmentId      String?
  departmentRef     Department? @relation("DepartmentMembers", fields: [departmentId], references: [id], onDelete: SetNull)
  levelId           String?
  levelRef          Level?      @relation("LevelMembers", fields: [levelId], references: [id], onDelete: SetNull)
  managerId         String?
  employeeId        String?
  startDate         DateTime?
  linkedInUrl       String?
  twitterHandle     String?
  githubHandle      String?
  country           String?
  city              String?
  address           String?
  skills            String[]
  certifications    Json     @default("[]")
  languages         String[]
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?
  notificationPrefs Json     @default("{}")
  dashboardLayout   Json     @default("{}")
  hrData            Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@index([tenantId, levelId])
  @@index([tenantId, managerId])
  @@unique([id, tenantId])
}

// ─── CRM System-Control: People / Org Structure ───────────────────────────────
// Additive, tenant-scoped org layer used by the CRM for system control (company
// profile, hierarchical departments, seniority levels, reporting lines). This is
// NOT a full HR module — HR lives in a separate service. All models carry
// `tenantId` and are auto-scoped by the tenant Prisma extension (see prisma.ts).

// Per-tenant company profile. One row per tenant (enforced by @@unique).
model Company {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  legalName    String?
  domain       String?
  logoUrl      String?
  industry     String?
  size         String?
  phone        String?
  website      String?
  street       String?
  city         String?
  state        String?
  country      String?
  postalCode   String?
  timezone     String?
  currency     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId])
  @@unique([id, tenantId])
}

// Hierarchical department. `parentDepartmentId` self-relation builds the tree.
model Department {
  id                 String       @id @default(cuid())
  tenantId           String
  name               String
  code               String?
  description        String?
  parentDepartmentId String?
  parent             Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  children           Department[] @relation("DepartmentHierarchy")
  headUserId         String?
  members            UserProfile[] @relation("DepartmentMembers")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([tenantId])
  @@index([tenantId, parentDepartmentId])
  @@unique([tenantId, name])
  @@unique([id, tenantId])
}

// Seniority / grade level. `rank` orders levels (lower = junior by convention).
model Level {
  id          String        @id @default(cuid())
  tenantId    String
  name        String
  rank        Int
  description String?
  members     UserProfile[] @relation("LevelMembers")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tenantId])
  @@unique([tenantId, name])
  @@unique([tenantId, rank])
  @@unique([id, tenantId])
}