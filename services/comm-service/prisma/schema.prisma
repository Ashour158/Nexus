generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/comm-client"
}

datasource db {
  provider = "postgresql"
  url      = env("COMM_DATABASE_URL")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  subject   String
  htmlBody  String   @db.Text
  textBody  String   @db.Text
  variables String[]
  category  String   @default("GENERAL")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@unique([id, tenantId])
}

model SmsTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  body      String   @db.Text
  variables String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@unique([id, tenantId])
}

model EmailSequence {
  id           String                 @id @default(cuid())
  tenantId     String
  name         String
  triggerType  String
  isActive     Boolean                @default(true)
  steps        SequenceStep[]
  enrollments  SequenceEnrollment[]
  createdAt    DateTime               @default(now())

  @@index([tenantId])
  @@unique([id, tenantId])
}

model SequenceStep {
  id         String        @id @default(cuid())
  sequenceId String
  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepNumber Int
  delayDays  Int           @default(0)
  templateId String

  @@unique([sequenceId, stepNumber])
}

model SequenceEnrollment {
  id          String        @id @default(cuid())
  tenantId    String
  sequenceId  String
  sequence    EmailSequence @relation(fields: [sequenceId], references: [id])
  contactId   String
  currentStep Int           @default(0)
  status      String        @default("ACTIVE")
  enrolledAt  DateTime      @default(now())
  nextSendAt  DateTime?

  @@index([tenantId])
  @@index([status, nextSendAt])
  @@index([sequenceId])
  @@unique([id, tenantId])
}

model CommOutbox {
  id           String    @id @default(cuid())
  tenantId     String
  channel      String
  to           String
  subject      String?
  body         String    @db.Text
  status       String    @default("QUEUED")
  templateId   String?
  entityType   String?
  entityId     String?
  sentAt       DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, status])
  @@unique([id, tenantId])
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}

/// CTI telephony call log (click-to-call + automatic call logging).
/// One row per placed/received call; updated by the provider status webhook.
model CallLog {
  id              String    @id @default(cuid())
  tenantId        String
  provider        String    @default("twilio")
  providerCallSid String?
  direction       String    @default("OUTBOUND")
  fromNumber      String
  toNumber        String
  agentUserId     String
  contactId       String?
  dealId          String?
  accountId       String?
  status          String    @default("INITIATED")
  outcome         String?
  durationSec     Int?
  recordingUrl    String?
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, contactId])
  @@index([providerCallSid])
  @@unique([id, tenantId])
}

/// WhatsApp Business API outbound/inbound thread (Prompt 32).
model WhatsAppMessage {
  id          String   @id @default(cuid())
  tenantId    String
  contactId   String?
  dealId      String?
  direction   String
  /// WhatsApp Phone Number ID or sender id (outbound metadata).
  from        String
  to          String
  body        String   @db.Text
  status      String
  externalId  String?
  sentBy      String?
  createdAt   DateTime @default(now())

  @@index([tenantId, contactId])
  @@index([externalId])
  @@unique([id, tenantId])
}