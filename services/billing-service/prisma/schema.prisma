generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/billing-client"
}

datasource db {
  provider = "postgresql"
  url      = env("BILLING_DATABASE_URL")
}

model Plan {
  id            String         @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  amount        Decimal        @db.Decimal(18, 2)
  currency      String         @default("USD")
  // Tenant/plan default tax rate as a PERCENT (e.g. 15.0000 = 15%) applied to
  // renewal + trial-conversion invoices. NULL/0 → falls back to
  // BILLING_DEFAULT_TAX_RATE_PERCENT env, then 0. finance-service owns the
  // canonical multi-zone tax calc; this is the billing-side default rate.
  taxRate       Decimal?       @db.Decimal(9, 4)
  interval      String         @default("MONTHLY")
  trialDays     Int            @default(0)
  features      Json           @default("[]")
  isActive      Boolean        @default(true)
  stripePriceId String?
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@unique([id, tenantId])
}

model Subscription {
  id                 String    @id @default(cuid())
  tenantId           String
  customerId         String
  planId             String
  plan               Plan      @relation(fields: [planId], references: [id])
  // Lifecycle status: TRIALING | ACTIVE | PAST_DUE | CANCELLED | EXPIRED | PAUSED
  status             String    @default("ACTIVE")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEnd           DateTime?
  // Renewal + dunning control (COM-05)
  autoRenew          Boolean   @default(true)
  cancelAtPeriodEnd  Boolean   @default(false)
  // Dunning bookkeeping — when a subscription entered PAST_DUE and how many
  // retry cycles have fired. Used by the poller to schedule day 1/3/5/7 retries.
  pastDueSince       DateTime?
  dunningAttempts    Int       @default(0)
  lastDunningAt      DateTime?
  cancelledAt        DateTime?
  stripeSubId        String?
  metadata           Json      @default("{}")
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  invoices           Invoice[]
  usageRecords       UsageRecord[]

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@index([status, currentPeriodEnd])
  @@unique([id, tenantId])
}

model Invoice {
  id              String        @id @default(cuid())
  tenantId        String
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  customerId      String
  number          String
  amount          Decimal       @db.Decimal(18, 2)
  currency        String        @default("USD")
  status          String        @default("DRAFT")
  dueDate         DateTime?
  paidAt          DateTime?
  lineItems       Json          @default("[]")
  stripeInvoiceId String?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  payments        Payment[]
  creditNotes     CreditNote[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@unique([id, tenantId])
}

model Payment {
  id                    String    @id @default(cuid())
  tenantId              String
  invoiceId             String
  invoice               Invoice   @relation(fields: [invoiceId], references: [id])
  amount                Decimal   @db.Decimal(18, 2)
  currency              String    @default("USD")
  method                String    @default("STRIPE")
  status                String    @default("PENDING")
  stripePaymentIntentId String?
  metadata              Json      @default("{}")
  failedAt              DateTime?
  completedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, invoiceId])
  @@index([tenantId, status])
  @@unique([id, tenantId])
}

// ─── Usage metering (COM-05) ──────────────────────────────────────────────────
// A single metered-usage datapoint for a subscription. Aggregated per-metric
// over the billing period and folded into the renewal invoice. `billedInvoiceId`
// marks the record as already invoiced so a period is never double-charged.
model UsageRecord {
  id              String       @id @default(cuid())
  tenantId        String
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id])
  metric          String
  quantity        Decimal      @db.Decimal(18, 4)
  // Optional per-unit price override; when null the plan feature/metadata rate
  // (or 0) is used at aggregation time.
  unitPrice       Decimal?     @db.Decimal(18, 6)
  ts              DateTime     @default(now())
  billedInvoiceId String?
  billedAt        DateTime?
  metadata        Json         @default("{}")
  createdAt       DateTime     @default(now())

  @@index([tenantId])
  @@index([tenantId, subscriptionId])
  @@index([subscriptionId, metric, billedInvoiceId])
  @@unique([id, tenantId])
}

// ─── Credit notes / refunds (COM-06) ──────────────────────────────────────────
// A credit issued against an invoice. Reduces the invoice's outstanding balance
// (see invoice outstanding calc). Decimal-safe; never mutates the invoice amount.
model CreditNote {
  id        String   @id @default(cuid())
  tenantId  String
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  customerId String?
  number    String
  amount    Decimal  @db.Decimal(18, 2)
  currency  String   @default("USD")
  reason    String
  // ISSUED | VOID
  status    String   @default("ISSUED")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, invoiceId])
  @@unique([id, tenantId])
}

model OutboxMessage {
  id            String    @id @default(cuid())
  topic         String
  tenantId      String?
  key           String?
  payload       Json
  aggregateId   String?
  eventType     String?
  correlationId String?
  headers       Json      @default("{}")
  status        String    @default("PENDING")
  error         String?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}
