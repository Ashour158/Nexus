generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/notes-client"
}

datasource db {
  provider = "postgresql"
  url      = env("NOTES_DATABASE_URL")
}

model Note {
  id         String   @id @default(cuid())
  tenantId   String
  authorId   String
  content    String
  isPinned   Boolean  @default(false)
  leadId     String?
  contactId  String?
  accountId  String?
  dealId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?
  @@index([tenantId])
  @@index([tenantId, dealId])
  @@index([tenantId, contactId])
  @@index([tenantId, accountId])
  @@index([tenantId, leadId])
  @@index([tenantId, authorId])
  @@index([tenantId, createdAt])
  @@unique([id, tenantId])
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}
