generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/auth-client"
}

datasource db {
  provider = "postgresql"
  // Same variable as runtime (`requireEnv(['DATABASE_URL', ...])`) and `services/auth-service/.env.example`.
  url      = env("AUTH_DATABASE_URL")
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  isActive    Boolean  @default(true)
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  roles       Role[]
  apiKeys     ApiKey[]
}

model User {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email           String
  emailVerified   Boolean       @default(false)
  keycloakId      String        @unique
  passwordHash    String?       // For local auth (bcrypt/scrypt)
  firstName       String
  lastName        String
  avatarUrl       String?
  phone           String?
  locale          String        @default("en")
  timezone        String        @default("UTC")
  isActive        Boolean       @default(true)
  lastLoginAt     DateTime?
  ssoProvider     String?
  bookingToken    String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  profile         UserProfile?
  userRoles       UserRole[]
  sessions        Session[]
  auditLogs       AuditLog[]
  passwordResets  PasswordReset[]
  mfaConfiguration MfaConfiguration?
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, createdAt])
  @@unique([id, tenantId])
}

model GdprErasureRequest {
  id            String   @id @default(uuid())
  tenantId      String
  subjectEmail  String?
  subjectId     String?
  requestedBy   String
  status        String   @default("PENDING")
  completedAt   DateTime?
  servicesAcked String[] @default([])
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@unique([id, tenantId])
}

model SsoConfiguration {
  tenantId     String   @id
  provider     String   @default("saml")
  entryPoint   String
  issuer       String
  certificate  String
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([tenantId, provider])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model Role {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  permissions Json         @default("[]")
  isSystem    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userRoles   UserRole[]
  @@unique([tenantId, name])
  @@unique([id, tenantId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, roleId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  mfaVerified  Boolean  @default(false)
  createdAt    DateTime @default(now())
  @@index([userId])
  @@index([expiresAt])
}

model MfaConfiguration {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret        String   // Base32-encoded TOTP secret (encrypted at application layer)
  method        String   @default("TOTP") // TOTP, SMS, EMAIL
  backupCodes   Json     @default("[]")   // Array of hashed backup codes
  enabledAt     DateTime?
  lastVerifiedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([userId])
}

model ApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String    @unique
  keyPrefix   String
  scopes      Json      @default("[]")
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  @@index([tenantId])
  @@unique([id, tenantId])
}

model IpRestriction {
  id          String   @id @default(cuid())
  tenantId    String
  type        String   // ALLOW or BLOCK
  cidr        String   // e.g., "192.168.1.0/24" or "10.0.0.1"
  description String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([tenantId])
  @@index([tenantId, type])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  resource   String
  resourceId String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  @@index([tenantId])
  @@index([tenantId, resource, resourceId])
  @@index([tenantId, createdAt])
  @@unique([id, tenantId])
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}

model UserProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId          String
  bio               String?
  dateOfBirth       DateTime?
  nationality       String?
  personalEmail     String?
  personalPhone     String?
  jobTitle          String?
  department        String?
  managerId         String?
  employeeId        String?
  startDate         DateTime?
  linkedInUrl       String?
  twitterHandle     String?
  githubHandle      String?
  country           String?
  city              String?
  address           String?
  skills            String[]
  certifications    Json     @default("[]")
  languages         String[]
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?
  notificationPrefs Json     @default("{}")
  dashboardLayout   Json     @default("{}")
  hrData            Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@unique([id, tenantId])
}