# ─── Finance Service ────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
LOG_LEVEL=info

# JWT verification — must match auth-service JWT_SECRET (HS256, >=32 chars).
JWT_SECRET=replace-me-with-at-least-32-characters-ok

# CORS origins (comma-separated).
CORS_ORIGINS=http://localhost:3000

# Primary database (Section 31.3).
FINANCE_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_finance

# Kafka (Section 36).
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=finance-service
KAFKA_SSL=false
