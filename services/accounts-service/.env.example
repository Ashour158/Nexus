ACCOUNTS_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_accounts
PORT=3031
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
JWT_SECRET=change-me-min-32-characters-long

# RS256 token verification via auth-service JWKS (optional). When set, this service
# verifies auth-issued RS256 JWTs by fetching auth-service public keys instead of
# using the static HS256 JWT_SECRET.
AUTH_JWKS_URL=http://localhost:3010/.well-known/jwks.json
