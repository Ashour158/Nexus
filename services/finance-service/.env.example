# -- Required ---------------------------------------------------------------
PORT=3002
NODE_ENV=development
FINANCE_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_finance
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=finance-service

# -- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# ZATCA / Saudi e-invoicing (sandbox or production)
ZATCA_API_URL=https://gw-fatoora.zatca.gov.sa/e-invoicing/developer-portal
ZATCA_CLIENT_ID=
ZATCA_CLIENT_SECRET=
ZATCA_SELLER_NAME=
ZATCA_SELLER_TRN=

# Discount approval → approval-service
APPROVAL_SERVICE_URL=http://approval-service:3014
DISCOUNT_APPROVAL_THRESHOLD=20
INTERNAL_SERVICE_TOKEN=

# -- Optional ---------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=
CHROMIUM_PATH=
