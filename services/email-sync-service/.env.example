# -- Required ---------------------------------------------------------------
PORT=3026
NODE_ENV=development
EMAIL_SYNC_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_email_sync
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/email/oauth/gmail/callback

# Redis
REDIS_URL=redis://:nexus@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=nexus

# CRM lookup (email -> contact/deal resolution). Optional service auth bearer.
CRM_SERVICE_URL=http://localhost:3001/api/v1
# NEXUS_SERVICE_JWT=
CRM_HTTP_TIMEOUT_MS=8000

# Kafka (email.received / email.sent / email.replied timeline events)
KAFKA_BROKERS=localhost:9092

# Background poller: syncs all enabled connections every N ms. 0/unset = disabled.
EMAIL_SYNC_POLL_INTERVAL_MS=0
