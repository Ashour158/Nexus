{
  "uid": "nexus-readiness",
  "title": "Nexus — Production Readiness",
  "description": "Operational panels mirror the provisioned Prometheus readiness alerts. HTTP SLI panels remain intentionally gated until request collectors emit samples.",
  "tags": ["nexus", "readiness", "alerts"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service targets down",
      "description": "Mirrors NexusServiceTargetDown (critical after 2 minutes).",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ] }
        }
      },
      "targets": [
        { "expr": "count(up{job=\"nexus-services\"} == 0) or vector(0)", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Targets missing HTTP telemetry",
      "description": "A non-zero value means 5xx-rate and request-latency alerting is blind for one or more scrapeable targets.",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 }
          ] }
        }
      },
      "targets": [
        {
          "expr": "count((up{job=\"nexus-services\"} == 1) unless on (job, instance) count by (job, instance) (nexus_http_requests_total{job=\"nexus-services\"})) or vector(0)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Targets restarting",
      "description": "Targets with more than two process starts in the last 15 minutes.",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 }
          ] }
        }
      },
      "targets": [
        { "expr": "count(changes(nexus_process_start_time_seconds{job=\"nexus-services\"}[15m]) > 2) or vector(0)", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Process CPU",
      "description": "NexusHighProcessCpu warns above 0.8 CPU-seconds/second for 10 minutes.",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 0.8 }
          ] }
        }
      },
      "targets": [
        {
          "expr": "rate(nexus_process_cpu_seconds_total{job=\"nexus-services\"}[5m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Node.js event-loop lag (p99)",
      "description": "NexusEventLoopLag warns above 500ms for 10 minutes. This is a runtime saturation signal, not request latency.",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 0.5 }
          ] }
        }
      },
      "targets": [
        {
          "expr": "nexus_nodejs_eventloop_lag_p99_seconds{job=\"nexus-services\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Resident memory",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "nexus_process_resident_memory_bytes{job=\"nexus-services\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    }
  ]
}
