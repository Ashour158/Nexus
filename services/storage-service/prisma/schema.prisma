generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/storage-client"
}

datasource db {
  provider = "postgresql"
  url      = env("STORAGE_DATABASE_URL")
}

model FileAttachment {
  id          String   @id @default(cuid())
  tenantId    String
  uploadedBy  String
  entityType  String
  entityId    String
  filename    String
  storedKey   String
  mimeType    String
  sizeBytes   Int
  url         String?
  createdAt   DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@unique([id, tenantId])
}

model StorageUsage {
  tenantId   String   @id
  bytesUsed  BigInt   @default(0)
  fileCount  Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}