# -- Required ---------------------------------------------------------------
PORT=3001
NODE_ENV=development
# Used at runtime and by Prisma (`prisma/schema.prisma` datasource). Copy this file to `.env` before `npx prisma migrate dev`.
CRM_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_crm
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=crm-service

# -- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -- Optional ---------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=
