generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/territory-client"
}

datasource db {
  provider = "postgresql"
  url      = env("TERRITORY_DATABASE_URL")
}

model Territory {
  id          String           @id @default(cuid())
  tenantId    String
  name        String
  description String?
  type        TerritoryType    @default(GEOGRAPHIC)
  ownerIds    String[]
  teamId      String?
  priority    Int              @default(0)
  isActive    Boolean          @default(true)
  isDefault   Boolean          @default(false)
  currency    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  rules       TerritoryRule[]
  routingLogs LeadRoutingLog[]

  @@index([tenantId])
  @@unique([id, tenantId])
}

model TerritoryRule {
  id          String    @id @default(cuid())
  territoryId String
  territory   Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  field       String
  operator    String
  value       String
  createdAt   DateTime  @default(now())
}

model LeadRoutingLog {
  id                 String     @id @default(cuid())
  tenantId           String
  leadId             String
  recordType         String     @default("LEAD")
  matchedTerritoryId String?
  territory          Territory? @relation(fields: [matchedTerritoryId], references: [id])
  matchedRuleIds     String[]
  viaDefault         Boolean    @default(false)
  assignedOwnerId    String?
  routedAt           DateTime   @default(now())

  @@index([tenantId, leadId])
  @@index([tenantId, recordType])
  @@unique([id, tenantId])
}

model RoundRobinState {
  id          String   @id @default(cuid())
  tenantId    String
  territoryId String
  lastIndex   Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, territoryId])
  @@unique([id, tenantId])
}

enum TerritoryType {
  GEOGRAPHIC
  INDUSTRY
  ACCOUNT_SIZE
  CUSTOM
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}