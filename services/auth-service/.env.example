# -- Required ---------------------------------------------------------------
PORT=3000
NODE_ENV=development
# Used at runtime and by Prisma (`prisma/schema.prisma` datasource). Copy this file to `.env` before `npx prisma migrate dev`.
AUTH_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_auth
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=auth-service

# -- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
APP_URL=http://localhost:3000

# Redis - must include password if Redis is configured with requirepass
REDIS_URL=redis://:nexus@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=nexus

# -- Encryption (required when ENCRYPTION_MASTER_KEY is set in other services) --
# Must be at least 32 characters. Used for field-level PII encryption (GDPR Art. 32).
ENCRYPTION_MASTER_KEY=change-me-min-32-chars-long!!!!!

# -- Optional ---------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=
