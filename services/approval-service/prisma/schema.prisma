generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/approval-client"
}

datasource db {
  provider = "postgresql"
  url      = env("APPROVAL_DATABASE_URL")
}

model ApprovalPolicy {
  id          String            @id @default(cuid())
  tenantId    String
  name        String
  module      String
  conditions  Json              @default("{}")
  steps       Json              @default("[]")
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  requests    ApprovalRequest[]

  @@index([tenantId, module])
  @@unique([id, tenantId])
}

model ApprovalRequest {
  id           String          @id @default(cuid())
  tenantId     String
  policyId     String
  policy       ApprovalPolicy  @relation(fields: [policyId], references: [id])
  module       String
  recordId     String
  requestedBy  String
  status       ApprovalStatus  @default(PENDING)
  currentStep  Int             @default(0)
  data         Json            @default("{}")
  comment      String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  steps        ApprovalStep[]

  @@index([tenantId, module, recordId])
  @@index([tenantId, status])
  @@index([tenantId, requestedBy, status])
  @@unique([id, tenantId])
}

model ApprovalStep {
  id         String          @id @default(cuid())
  requestId  String
  request    ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  order      Int
  approverId String
  status     StepStatus      @default(PENDING)
  comment    String?
  actionedAt DateTime?
  createdAt  DateTime        @default(now())
  // Quorum config for the level this step belongs to (all steps sharing the
  // same `order` form one parallel level and carry the same values). Defaults
  // preserve legacy behavior: ALL with one step per level == all-must-approve.
  quorumMode QuorumMode      @default(ALL)
  quorumSize Int?

  @@index([requestId])
  @@index([approverId, status])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  CANCELLED
}

enum StepStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
  DELEGATED
}

enum QuorumMode {
  ALL
  ANY
  N_OF_M
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}