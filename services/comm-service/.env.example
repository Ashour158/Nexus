# -- Required ---------------------------------------------------------------
PORT=3009
NODE_ENV=development
COMM_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_comm
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=comm-service

# -- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# Redis - must include password if Redis is configured with requirepass
REDIS_URL=redis://:nexus@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=nexus

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v19.0
# Optional: public HTTPS PDF URL template for send-quote document messages, e.g. https://cdn.example.com/quotes/{quoteId}.pdf
WHATSAPP_QUOTE_DOCUMENT_URL_TEMPLATE=
FINANCE_SERVICE_URL=http://finance-service:3002
INTERNAL_SERVICE_TOKEN=

# -- SMTP (email delivery) ---------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@example.com

# -- Twilio (SMS) ------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567

# -- CTI Telephony (click-to-call + auto call logging, Twilio Voice) ---------
# Reuses TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN above. Leave TWILIO_CALLER_ID
# blank to keep click-to-call disabled (endpoint returns 503 requiresConfig).
TWILIO_CALLER_ID=+15551234567
# Public URL Twilio POSTs call status/duration/recording to (POST, urlencoded).
# Also used to reconstruct the signed URL for X-Twilio-Signature verification.
TELEPHONY_STATUS_CALLBACK_URL=
# TwiML the call executes once answered (defaults to Twilio's demo TwiML).
TELEPHONY_TWIML_URL=

# -- Tracking webhook HMAC (min 32 chars) ------------------------------------
TRACKING_SECRET=change-me-to-a-random-32-char-string

# -- Internal service URLs ---------------------------------------------------
NEXUS_SERVICE_JWT=internal-service-token
CRM_SERVICE_URL=http://crm-service:3001
AUTH_SERVICE_URL=http://auth-service:3000

# -- Optional ---------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=
