generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/comm-client"
}

datasource db {
  provider = "postgresql"
  url      = env("COMM_DATABASE_URL")
}

/// Unified template store for the WYSIWYG Template Designer. Despite the
/// legacy name, a row can represent an EMAIL, SMS, or DOCUMENT template via the
/// `type` discriminator. Existing email rows keep `type = "EMAIL"` (the
/// default) and are unaffected. `subject`/`textBody` carry `@default("")` so
/// DOCUMENT/SMS rows that only need an HTML `htmlBody` can be created without
/// them; pre-existing rows already hold their own values.
model EmailTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  /// EMAIL | SMS | DOCUMENT
  type      String   @default("EMAIL")
  /// Target CRM module for merge fields: lead | contact | account | deal | quote
  module    String?
  subject   String   @default("")
  htmlBody  String   @db.Text
  textBody  String   @default("") @db.Text
  variables String[]
  category  String   @default("GENERAL")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, type])
  @@unique([id, tenantId])
}

model SmsTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  body      String   @db.Text
  variables String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@unique([id, tenantId])
}

model EmailSequence {
  id           String                 @id @default(cuid())
  tenantId     String
  name         String
  triggerType  String
  isActive     Boolean                @default(true)
  steps        SequenceStep[]
  enrollments  SequenceEnrollment[]
  createdAt    DateTime               @default(now())

  @@index([tenantId])
  @@unique([id, tenantId])
}

model SequenceStep {
  id         String        @id @default(cuid())
  sequenceId String
  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepNumber Int
  delayDays  Int           @default(0)
  templateId String

  @@unique([sequenceId, stepNumber])
}

model SequenceEnrollment {
  id          String        @id @default(cuid())
  tenantId    String
  sequenceId  String
  sequence    EmailSequence @relation(fields: [sequenceId], references: [id])
  contactId   String
  currentStep Int           @default(0)
  status      String        @default("ACTIVE")
  enrolledAt  DateTime      @default(now())
  nextSendAt  DateTime?

  @@index([tenantId])
  @@index([status, nextSendAt])
  @@index([sequenceId])
  @@unique([id, tenantId])
}

model CommOutbox {
  id           String    @id @default(cuid())
  tenantId     String
  channel      String
  to           String
  subject      String?
  body         String    @db.Text
  status       String    @default("QUEUED")
  templateId   String?
  /// Optional per-user MailAccount to send THROUGH (SMTP/OAuth of the user's own
  /// mail provider). Null → send via the global/system SMTP transport.
  mailAccountId String?
  entityType   String?
  entityId     String?
  sentAt       DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, status])
  @@unique([id, tenantId])
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}

/// CTI telephony call log (click-to-call + automatic call logging).
/// One row per placed/received call; updated by the provider status webhook.
model CallLog {
  id              String    @id @default(cuid())
  tenantId        String
  provider        String    @default("twilio")
  providerCallSid String?
  direction       String    @default("OUTBOUND")
  fromNumber      String
  toNumber        String
  agentUserId     String
  contactId       String?
  dealId          String?
  accountId       String?
  status          String    @default("INITIATED")
  outcome         String?
  durationSec     Int?
  recordingUrl    String?
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, contactId])
  @@index([providerCallSid])
  @@unique([id, tenantId])
}

/// WhatsApp Business API outbound/inbound thread (Prompt 32).
model WhatsAppMessage {
  id          String   @id @default(cuid())
  tenantId    String
  contactId   String?
  dealId      String?
  direction   String
  /// WhatsApp Phone Number ID or sender id (outbound metadata).
  from        String
  to          String
  body        String   @db.Text
  status      String
  externalId  String?
  sentBy      String?
  createdAt   DateTime @default(now())

  @@index([tenantId, contactId])
  @@index([externalId])
  @@unique([id, tenantId])
}

/// Per-user / per-tenant mail-provider account. Lets a user register their OWN
/// mail account (SMTP/IMAP creds or an OAuth Gmail/Outlook token) so outbound
/// email can be sent FROM their address instead of the global system SMTP.
///
/// Secrets are NEVER stored in cleartext: SMTP passwords and OAuth tokens are
/// encrypted at rest with AES-256-GCM (same field-crypto mechanism as
/// integration-service) using the platform ENCRYPTION_MASTER_KEY. API responses
/// always mask them.
model MailAccount {
  id          String    @id @default(cuid())
  tenantId    String
  /// Owner (JWT sub). A user manages only their own accounts.
  userId      String
  /// SMTP | GMAIL | OUTLOOK
  provider    String    @default("SMTP")
  displayName String
  fromEmail   String
  fromName    String?
  isDefault   Boolean   @default(false)
  isActive    Boolean   @default(true)
  /// Set when a successful connection test (SMTP verify / OAuth token check) ran.
  verifiedAt  DateTime?
  /// Last verify/send error, surfaced to the UI. Cleared on success.
  lastError   String?

  // ── SMTP provider config (encrypted secret) ──────────────────────────────
  smtpHost        String?
  smtpPort        Int?
  smtpSecure      Boolean?
  smtpUsername    String?
  /// AES-256-GCM encrypted SMTP password blob (base64url iv|tag|ciphertext).
  smtpPasswordEnc String?   @db.Text

  // ── OAuth provider config (encrypted tokens) — Gmail / Outlook ───────────
  /// AES-256-GCM encrypted OAuth access token blob.
  oauthAccessTokenEnc  String?   @db.Text
  /// AES-256-GCM encrypted OAuth refresh token blob.
  oauthRefreshTokenEnc String?   @db.Text
  oauthExpiresAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, userId])
  @@unique([tenantId, userId, fromEmail])
  @@unique([id, tenantId])
}