# -- Required ---------------------------------------------------------------
PORT=3003
NODE_ENV=development
NOTIFICATION_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_notification
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=notification-service

# -- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# Redis - must include password if Redis is configured with requirepass
REDIS_URL=redis://:nexus@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=nexus

# -- Optional ---------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=

# -- SMS channel (optional) -------------------------------------------------
# Twilio via REST (no SDK). All three must be set to enable SMS; otherwise the
# SMS channel is a no-op.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# -- Push channel (optional) ------------------------------------------------
# Firebase Cloud Messaging HTTP v1. Set ALL THREE from a Google service-account
# JSON key to enable push; leave any unset and the channel is a no-op
# (/health/channels reports push=false). The legacy FCM_SERVER_KEY / WEB_PUSH_*
# server-key API was retired by Google and is no longer supported.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
# Service-account private key (PEM). Literal "\n" escapes are accepted and
# normalised to newlines, so the one-line JSON value can be pasted as-is.
FCM_PRIVATE_KEY=

# -- WhatsApp channel (optional) --------------------------------------------
# Outbound WhatsApp mirrors SMS/push. Two providers are supported; the channel
# auto-selects. If neither is configured the WhatsApp channel is a no-op.
#
# Provider A — Twilio WhatsApp (reuses the Twilio creds above). Set the
# WhatsApp-enabled sender number to enable it (e.g. the Twilio sandbox number):
TWILIO_WHATSAPP_FROM=
#
# Provider B — WhatsApp Cloud API (Meta). Used when TWILIO_WHATSAPP_FROM is not
# set. Supports freeform text and named templates:
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
# Optional Graph API version override (defaults to v20.0):
WHATSAPP_API_VERSION=

# -- Inbound WhatsApp webhook (optional) ------------------------------------
# POST /api/v1/webhooks/whatsapp (WhatsApp Cloud API). Emits `whatsapp.received`
# on the comms topic for downstream timeline correlation. Fully guarded: if
# these are unset, inbound WhatsApp is disabled and the webhook no-ops.
# Meta app secret used to HMAC-verify inbound payloads (x-hub-signature-256):
WHATSAPP_APP_SECRET=
# Token echoed back on the GET subscription-verification handshake:
WHATSAPP_VERIFY_TOKEN=
# Tenant that inbound WhatsApp messages are attributed to (required for inbound):
WHATSAPP_WEBHOOK_TENANT_ID=
