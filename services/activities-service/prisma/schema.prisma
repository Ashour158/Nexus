generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/activities-client"
}

datasource db {
  provider = "postgresql"
  url      = env("ACTIVITIES_DATABASE_URL")
}

model Activity {
  id           String         @id @default(cuid())
  tenantId     String
  ownerId      String
  type         ActivityType
  subject      String
  description  String?
  status       ActivityStatus @default(PLANNED)
  priority     ActivityPriority @default(NORMAL)
  dueDate      DateTime?
  startDate    DateTime?
  endDate      DateTime?
  duration     Int?
  outcome      String?
  leadId       String?
  contactId    String?
  accountId    String?
  dealId       String?
  customFields Json           @default("{}")
  // Set once a due-date reminder notification has been emitted for this activity,
  // so restarts / overlapping poller ticks never re-send it (idempotency flag).
  reminderSentAt   DateTime?
  // Set once an overdue notification/escalation event has been emitted, so an
  // activity is only flagged overdue a single time (idempotency flag).
  overdueNotifiedAt DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@index([tenantId, dealId])
  @@index([tenantId, contactId])
  @@index([tenantId, accountId])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, ownerId, dueDate, status])
  @@index([tenantId, createdAt])
  // Poller scan indexes: find not-yet-notified activities by due date.
  @@index([status, dueDate, reminderSentAt])
  @@index([status, dueDate, overdueNotifiedAt])
  @@unique([id, tenantId])
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  TASK
  DEMO
  LUNCH
  CONFERENCE
  FOLLOW_UP
  PROPOSAL
  NEGOTIATION
  NOTE
}

enum ActivityStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DEFERRED
}

enum ActivityPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model EmailThread {
  id            String         @id @default(cuid())
  tenantId      String
  contactId     String?
  accountId     String?
  externalId    String
  subject       String
  provider      String
  lastMessageAt DateTime       @default(now())
  messageCount  Int            @default(1)
  isRead        Boolean        @default(false)
  snippet       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  messages      EmailMessage[]

  @@unique([tenantId, provider, externalId])
  @@index([tenantId, contactId])
  @@index([tenantId, accountId])
  @@unique([id, tenantId])
}

model EmailMessage {
  id         String      @id @default(cuid())
  threadId   String
  thread     EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  externalId String
  fromEmail  String
  toEmails   String[]
  ccEmails   String[]
  subject    String
  bodyHtml   String?
  bodyText   String?
  sentAt     DateTime
  direction  String
  createdAt  DateTime    @default(now())

  @@index([threadId])
}

model Attachment {
  id          String   @id @default(cuid())
  tenantId    String
  module      String
  recordId    String
  fileName    String
  fileSize    Int
  mimeType    String
  storageKey  String
  uploadedBy  String
  createdAt   DateTime @default(now())

  @@index([tenantId, module, recordId])
  @@unique([id, tenantId])
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}