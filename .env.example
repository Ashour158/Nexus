# =============================================================================
# NEXUS CRM — Service-Specific Database URLs
# =============================================================================
# CRITICAL: Each microservice MUST have its own dedicated PostgreSQL database.
# Sharing DATABASE_URL across services is a distributed-monolith anti-pattern.
# It breaks data ownership, prevents independent scaling, and creates coupling.
# =============================================================================

# ─── CRM Core ───────────────────────────────────────────────────────────────
CRM_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_crm
CONTACTS_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_contacts
DEALS_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_deals
ACTIVITIES_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_activities
METADATA_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_metadata

# ─── Auth & Identity ────────────────────────────────────────────────────────
AUTH_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_auth

# ─── Communication ──────────────────────────────────────────────────────────
COMM_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_comm

# ─── Integration & Webhooks ─────────────────────────────────────────────────
INTEGRATION_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_integration

# ─── Notification ───────────────────────────────────────────────────────────
NOTIFICATION_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_notification

# ─── Storage & Files ────────────────────────────────────────────────────────
STORAGE_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_storage

# ─── Workflow & Automation ──────────────────────────────────────────────────
WORKFLOW_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_workflow

# ─── Approval Engine ────────────────────────────────────────────────────────
APPROVAL_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_approval

# ─── Cadence & Sequences ────────────────────────────────────────────────────
CADENCE_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_cadence
COMM_SERVICE_URL=http://localhost:3009
METADATA_SERVICE_URL=http://localhost:3004
PORT=3018

# ─── Territory & Routing ────────────────────────────────────────────────────
TERRITORY_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_territory
PORT=3019

# ─── Planning & Forecasting ─────────────────────────────────────────────────
PLANNING_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_planning
ANALYTICS_SERVICE_URL=http://localhost:3008
PORT=3020

# ─── Reporting & Analytics ──────────────────────────────────────────────────
REPORTING_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_reporting
REPORTING_SERVICE_URL=http://localhost:3021
PORT=3021

# ─── Customer Portal ────────────────────────────────────────────────────────
PORTAL_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_portal
FINANCE_SERVICE_URL=http://localhost:3003
APP_URL=http://localhost:3000
PORT=3022

# ─── Knowledge Base ─────────────────────────────────────────────────────────
KNOWLEDGE_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_knowledge
PORT=3023

# ─── Incentives & Gamification ──────────────────────────────────────────────
INCENTIVE_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_incentive
PORT=3024

# ─── Chatbot ────────────────────────────────────────────────────────────────
CHATBOT_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_chatbot
PORT=3017

# ─── Data Import / Export ───────────────────────────────────────────────────
DATA_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_data
PORT=3015

# ─── CRM Decomposition (new microservices) ──────────────────────────────────
LEADS_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_leads
ACCOUNTS_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_accounts
NOTES_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_notes
QUOTES_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_quotes

# ─── Documents ──────────────────────────────────────────────────────────────
DOCUMENT_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_documents
PORT=3016

# ─── Finance (CPQ, Invoices, Commissions) ───────────────────────────────────
FINANCE_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_finance
PORT=3003

# ─── Email Sync ─────────────────────────────────────────────────────────────
EMAIL_SYNC_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_email_sync
EMAIL_SYNC_SERVICE_URL=http://email-sync-service:3026
PORT=3026

# ─── Blueprint / Playbooks ──────────────────────────────────────────────────
BLUEPRINT_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_blueprint

# Outbox Relay (reads from all service DBs; uses AUTH_DB for schema validation)
OUTBOX_RELAY_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_auth
ANALYTICS_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_analytics
PORT=3013

# ─── Integration Service OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3012/api/v1/integrations/oauth/google/callback
GOOGLE_MAPS_API_KEY=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3012/api/v1/integrations/oauth/microsoft/callback
INTEGRATION_ENCRYPTION_KEY=32-char-random-string-here
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Email Sync (Gmail OAuth) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/email/oauth/gmail/callback

# ─── Email Sync (Outlook OAuth) ─────────────────────────────────────────────
MICROSOFT_CLIENT_ID=your_ms_client_id
MICROSOFT_CLIENT_SECRET=your_ms_client_secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/email/oauth/outlook/callback

# ─── E-Signature (DocuSign) ─────────────────────────────────────────────────
DOCUSIGN_INTEGRATION_KEY=your_docusign_integration_key
DOCUSIGN_CLIENT_SECRET=your_docusign_client_secret
DOCUSIGN_REDIRECT_URI=http://localhost:3000/api/esign/docusign/callback
DOCUSIGN_ACCOUNT_ID=your_docusign_account_id
DOCUSIGN_WEBHOOK_SECRET=your_docusign_webhook_secret

# ─── Backup ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus
BACKUP_RETENTION_DAYS=30

# ─── Error Monitoring ───────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=nexus-local

# ─── Redis (required for production idempotency) ────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Read Replica (optional — falls back to primary if unset) ───────────────
# Format: postgresql://nexus:nexus@localhost:5433/nexus
# Set per-service to offload read queries. Uses packages/service-utils prisma-client.ts
DATABASE_READ_REPLICA_URL=

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-min-32-characters-long

# ─── Field-Level Encryption (PII) ───────────────────────────────────────────
# REQUIRED for production. Must be ≥32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If absent, PII fields (email, phone, address) will NOT be encrypted.
ENCRYPTION_MASTER_KEY=change-me-min-32-characters-for-pii-encryption-key

# ─── MFA / TOTP Encryption ──────────────────────────────────────────────────
# Separate key for encrypting TOTP secrets. Must be ≥32 characters.
# Falls back to JWT_SECRET if not set (not recommended for production).
MFA_ENCRYPTION_KEY=change-me-min-32-chars-for-mfa-encryption-key

# ─── MFA Issuer Name ────────────────────────────────────────────────────────
MFA_ISSUER=NEXUS CRM

# ─── Keycloak OIDC ──────────────────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=nexus
KEYCLOAK_ADMIN_CLIENT_ID=nexus-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me-keycloak-secret
AUTH_JWKS_URL=http://auth-service:3000/.well-known/jwks.json
# Generate RSA key pair: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nchange-me\n-----END PUBLIC KEY-----"
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nchange-me\n-----END PRIVATE KEY-----"

# ─── SAML SSO ───────────────────────────────────────────────────────────────
SAML_ENTRY_POINT=https://idp.example.com/sso/saml
SAML_ISSUER=https://nexus.example.com
SAML_CERT=MIIC...base64cert
SAML_CALLBACK_URL=https://nexus.example.com/auth/sso/callback

# ─── ClickHouse Analytics ───────────────────────────────────────────────────
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=nexus_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me-clickhouse-password
