# -- Required ---------------------------------------------------------------
PORT=3006
NODE_ENV=development
SEARCH_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_search
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=search-service

# -- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -- Meilisearch ------------------------------------------------------------
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=

# -- Reindex (RR-H22) -------------------------------------------------------
# POST /api/v1/search/reindex re-hydrates the Meili indexes from the owning
# services' internal list endpoints. It requires the shared service token and
# the owning-service base URLs below; an unset base URL means that entity's
# source is skipped (with a warning) rather than failing the job.
INTERNAL_SERVICE_TOKEN=
CRM_SERVICE_URL=http://localhost:3005          # deals/contacts/accounts/leads/activities
FINANCE_SERVICE_URL=http://localhost:3007      # quotes
KNOWLEDGE_SERVICE_URL=http://localhost:3021    # kb articles
# Optional tuning (defaults shown):
# REINDEX_PAGE_SIZE=500
# REINDEX_MAX_PER_INDEX=50000

# -- Optional ---------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=
