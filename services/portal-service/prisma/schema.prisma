generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/portal-client"
}

datasource db {
  provider = "postgresql"
  url      = env("PORTAL_DATABASE_URL")
}

model PortalToken {
  id         String     @id @default(cuid())
  tenantId   String
  token      String     @unique @default(cuid())
  entityType EntityType
  entityId   String
  expiresAt  DateTime
  viewCount  Int        @default(0)
  createdBy  String
  createdAt  DateTime   @default(now())

  @@index([token])
  @@index([tenantId, entityId])
  @@unique([id, tenantId])
}

model PortalBranding {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  logoUrl      String?
  primaryColor String   @default("#3B82F6")
  companyName  String?
  updatedAt    DateTime @updatedAt
  @@unique([id, tenantId])
}

enum EntityType {
  QUOTE
  CONTRACT
  INVOICE
  ACCOUNT
}

model PortalAuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  token      String
  entityType String
  entityId   String
  action     String
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([token])
  @@index([entityId])
  @@index([createdAt])
  @@unique([id, tenantId])
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}