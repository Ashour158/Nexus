PORT=3010
AUTH_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_auth?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=change_me_minimum_32_chars________
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
CORS_ORIGINS=http://localhost:3000

DEFAULT_TENANT_SLUG=default

KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=nexus
KEYCLOAK_CLIENT_ID=nexus-api
KEYCLOAK_CLIENT_SECRET=keycloak-client-secret
# Set to 1 if access tokens omit `aud` for your realm/client.
# KEYCLOAK_SKIP_AUDIENCE=1

# Keycloak Admin API (client credentials) — required for POST /users/invite
KEYCLOAK_ADMIN_CLIENT_ID=nexus-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=admin-client-secret
# Realm used for the token endpoint (defaults to KEYCLOAK_REALM)
# KEYCLOAK_ADMIN_TOKEN_REALM=nexus
