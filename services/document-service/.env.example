# -- Required ---------------------------------------------------------------
PORT=3016
NODE_ENV=development
DOCUMENT_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_document
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=document-service

# -- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -- DocuSign (optional — set to enable e-signature) -----------------------
# DOCUSIGN_ACCOUNT_ID=your-account-id
# DOCUSIGN_ACCESS_TOKEN=your-oauth-access-token
# DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi

# -- MinIO / S3 object storage (optional — set to persist rendered/e-sign PDFs) -
# When unset, rendered PDFs are still returned inline (base64/binary) as before.
# document-service talks to MinIO over HTTP via AWS SigV4 (no `minio` package).
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY=your-access-key
# MINIO_SECRET_KEY=your-secret-key
# MINIO_BUCKET=nexus-documents
# MINIO_REGION=us-east-1

# -- Optional ---------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=
