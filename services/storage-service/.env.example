# -- Required ---------------------------------------------------------------
PORT=3010
NODE_ENV=development
STORAGE_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_storage
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=storage-service

# -- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -- Optional ---------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=nexus
MINIO_SECRET_KEY=nexus-minio
MINIO_BUCKET=nexus-files
MINIO_USE_SSL=false

# -- Usage / quota ----------------------------------------------------------
# Per-tenant byte quota. 0 or unset = unlimited (no enforcement). Quota checks
# are fail-open: a lookup failure allows the upload.
STORAGE_TENANT_QUOTA_BYTES=0

# -- Orphan cleanup poller (fail-open, OFF by default; deletes bucket objects) --
# Removes MinIO objects that have no FileAttachment row and are older than the
# grace window. Enable explicitly.
STORAGE_ORPHAN_CLEANUP_ENABLED=false
STORAGE_ORPHAN_POLL_MS=21600000
STORAGE_ORPHAN_GRACE_MS=86400000
STORAGE_ORPHAN_BATCH=500

