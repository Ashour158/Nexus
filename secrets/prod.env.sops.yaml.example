# Template for the encrypted production secrets bundle.
# Copy to `secrets/prod.env.sops.yaml`, fill REAL values, then `sops -e -i secrets/prod.env.sops.yaml`.
# The DEPLOY step decrypts it to a runtime .env that is NEVER committed:
#   sops -d secrets/prod.env.sops.yaml > .env   # (.env is gitignored — safe from `git reset --hard`)
#
# Rotate every secret during the cutover (assume the old plaintext .env values are compromised).
JWT_SECRET: 'CHANGE_ME_min_32_chars'
POSTGRES_PASSWORD: 'CHANGE_ME'
REDIS_PASSWORD: 'CHANGE_ME'
INTERNAL_SERVICE_TOKEN: 'CHANGE_ME'
# Managed-Postgres connection (once provisioned) — per-service or a shared base:
DATABASE_URL: 'postgresql://USER:PASS@MANAGED_HOST:25060/nexus?sslmode=require'
# Provider keys, if/when used (out of scope for this platform per the AI/3rd-party exclusion):
# CLEARBIT_API_KEY: ''
# APOLLO_API_KEY: ''
