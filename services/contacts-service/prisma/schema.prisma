generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/contacts-client"
}

datasource db {
  provider = "postgresql"
  url      = env("CONTACTS_DATABASE_URL")
}

model Contact {
  id              String       @id @default(cuid())
  tenantId        String
  ownerId         String
  accountId       String
  account         Account      @relation(fields: [accountId], references: [id])
  code            String?
  firstName       String
  lastName        String
  email           String?
  phone           String?
  mobile          String?
  jobTitle        String?
  department      String?
  linkedInUrl     String?
  twitterHandle   String?
  country         String?
  city            String?
  address         String?
  timezone        String?
  preferredChannel String?
  lifecycleStage String       @default("New relationship")
  buyingCommitteeRole String?
  influenceLevel String?
  relationshipScore Int       @default(0)
  slaStatus      String       @default("needs-first-touch")
  doNotEmail      Boolean      @default(false)
  doNotCall       Boolean      @default(false)
  gdprConsent     Boolean      @default(false)
  gdprConsentAt   DateTime?
  lastContactedAt DateTime?
  customFields    Json         @default("{}")
  tags            String[]
  isActive        Boolean      @default(true)
  dataQualityScore Int?
  archivedAt      DateTime?
  archivedBy      String?
  archiveReason   String?
  mergedIntoContactId String?
  version         Int          @default(1)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  notes           Note[]
  consents        ConsentRecord[]
  documents       ContactDocument[]
  auditEvents     ContactAuditEvent[]
  fieldHistory    ContactFieldHistory[]
  lifecycleEvents ContactLifecycleEvent[]
  mailThreads     ContactMailThread[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, accountId])
  @@index([tenantId, ownerId])
  @@index([tenantId, isActive])
  @@index([tenantId, archivedAt])
  @@index([tenantId, lifecycleStage])
  @@index([tenantId, slaStatus])
  @@index([tenantId, mergedIntoContactId])
  @@index([tenantId, email])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([tenantId, lastName])
  @@index([tenantId, code])
  @@unique([id, tenantId])
}

model ContactDocument {
  id                String    @id @default(cuid())
  tenantId          String
  contactId         String
  contact           Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  name              String
  type              String    @default("General")
  mimeType          String
  size              Int       @default(0)
  version           Int       @default(1)
  storageKey        String
  checksum          String?
  scanStatus        String    @default("PENDING")
  retentionCategory String    @default("customer-record")
  uploadedBy        String
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([id, tenantId])
  @@index([tenantId, contactId])
  @@index([tenantId, scanStatus])
  @@index([tenantId, retentionCategory])
}

model ContactAuditEvent {
  id          String   @id @default(cuid())
  tenantId    String
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  action      String
  actorId     String
  metadata    Json     @default("{}")
  occurredAt  DateTime @default(now())

  @@unique([id, tenantId])
  @@index([tenantId, contactId, occurredAt])
  @@index([tenantId, action])
}

model ContactFieldHistory {
  id          String   @id @default(cuid())
  tenantId    String
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  fieldName   String
  oldValue    Json?
  newValue    Json?
  changedBy   String
  changedAt   DateTime @default(now())

  @@unique([id, tenantId])
  @@index([tenantId, contactId, changedAt])
  @@index([tenantId, fieldName])
}

model ContactLifecycleEvent {
  id          String   @id @default(cuid())
  tenantId    String
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  fromStage   String?
  toStage     String
  reason      String?
  actorId     String
  occurredAt  DateTime @default(now())

  @@unique([id, tenantId])
  @@index([tenantId, contactId, occurredAt])
  @@index([tenantId, toStage])
}

model ContactMailThread {
  id            String    @id @default(cuid())
  tenantId      String
  contactId     String
  contact       Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  provider      String
  externalId    String
  subject       String
  fromEmail     String?
  toEmails      String[]  @default([])
  messageCount  Int       @default(1)
  lastMessageAt DateTime  @default(now())
  snippet       String?
  isRead        Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, provider, externalId])
  @@unique([id, tenantId])
  @@index([tenantId, contactId])
  @@index([tenantId, lastMessageAt])
}

model ConsentRecord {
  id          String    @id @default(cuid())
  tenantId    String
  contactId   String
  channel     String
  status      String
  grantedAt   DateTime?
  withdrawnAt DateTime?
  expiresAt   DateTime?
  source      String?
  ipAddress   String?
  notes       String?
  recordedBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([tenantId, contactId, channel])
  @@index([tenantId, contactId])
  @@index([tenantId, status])
  @@unique([id, tenantId])
}

model Account {
  id                         String        @id @default(cuid())
  tenantId                   String
  ownerId                    String
  parentAccountId            String?
  parentAccount              Account?      @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  childAccounts              Account[]     @relation("AccountHierarchy")
  code                       String?
  name                       String
  legalName                  String?
  tradeName                  String?
  website                    String?
  phone                      String?
  fax                        String?
  email                      String?
  industry                   String?
  subIndustry                String?
  type                       AccountType   @default(PROSPECT)
  tier                       AccountTier   @default(SMB)
  status                     AccountStatus @default(ACTIVE)
  lifecycleStage             String?
  annualRevenue              Decimal?      @db.Decimal(18, 2)
  employeeCount              Int?
  foundedYear                Int?
  country                    String?
  city                       String?
  address                    String?
  zipCode                    String?
  linkedInUrl                String?
  description                String?
  sicCode                    String?
  naicsCode                  String?
  taxId                      String?
  vatNumber                  String?
  commercialRegistrationNumber String?
  paymentTerms               String?
  creditLimit                Decimal?      @db.Decimal(18, 2)
  currency                   String?       @default("USD")
  priceBookId                String?
  territoryId                String?
  healthScore                Int?
  npsScore                   Int?
  riskLevel                  String?       @default("low")
  lastActivityAt             DateTime?
  billingAddressLine1        String?
  billingAddressLine2        String?
  billingCity                String?
  billingState               String?
  billingPostalCode          String?
  billingCountry             String?
  billingLatitude            Float?
  billingLongitude           Float?
  shippingAddressLine1       String?
  shippingAddressLine2       String?
  shippingCity               String?
  shippingState              String?
  shippingPostalCode         String?
  shippingCountry            String?
  shippingLatitude           Float?
  shippingLongitude          Float?
  shippingInstructions       String?
  sameAsBilling              Boolean       @default(false)
  customFields               Json          @default("{}")
  lat                        Float?
  lng                        Float?
  tags                       String[]
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  contacts                   Contact[]
  notes                      Note[]
  dataQualityScore           Int?

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, ownerId])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([tenantId, code])
  @@unique([id, tenantId])
}

enum AccountType {
  PROSPECT
  CUSTOMER
  PARTNER
  COMPETITOR
  RESELLER
  OTHER
}

enum AccountTier {
  STRATEGIC
  ENTERPRISE
  MID_MARKET
  SMB
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  AT_RISK
  CHURNED
}

model Company {
  id           String    @id @default(cuid())
  tenantId     String
  ownerId      String
  name         String
  website      String?
  phone        String?
  email        String?
  industry     String?
  type         String    @default("CUSTOMER")
  size         String?
  annualRevenue Decimal? @db.Decimal(18, 2)
  employeeCount Int?
  country      String?
  city         String?
  address      String?
  zipCode      String?
  linkedInUrl  String?
  description  String?
  customFields Json      @default("{}")
  tags         String[]
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, ownerId])
  @@unique([id, tenantId])
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}

model Note {
  id         String   @id @default(cuid())
  tenantId   String
  authorId   String
  content    String
  isPinned   Boolean  @default(false)
  leadId     String?
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id])
  accountId  String?
  account    Account? @relation(fields: [accountId], references: [id])
  dealId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, dealId])
  @@unique([id, tenantId])
}
