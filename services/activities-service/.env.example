# -- Required ---------------------------------------------------------------
PORT=3043
NODE_ENV=development
ACTIVITIES_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_activities
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=activities-service

# -- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -- Optional ---------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=

# RS256 token verification via auth-service JWKS (optional). When set, this service
# verifies auth-issued RS256 JWTs by fetching auth-service public keys instead of
# using the static HS256 JWT_SECRET.
AUTH_JWKS_URL=http://localhost:3010/.well-known/jwks.json
