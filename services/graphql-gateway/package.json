{
  "name": "@nexus/graphql-gateway",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "compose": "rover supergraph compose --config supergraph.yaml --output supergraph.graphql --elv2-license=accept",
    "dev": "rover dev --supergraph-config supergraph.yaml",
    "build": "node -e \"const fs=require('fs');fs.mkdirSync('dist',{recursive:true});fs.copyFileSync('supergraph.graphql','dist/supergraph.graphql')\"",
    "typecheck": "echo 'No TypeScript files in gateway'",
    "test": "vitest run"
  },
  "devDependencies": {
    "@apollo/rover": "^0.23.0"
  }
}
