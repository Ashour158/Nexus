# -- Required ---------------------------------------------------------------
PORT=3003
NODE_ENV=development
NOTIFICATION_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_notification
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=notification-service

# -- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# Redis - must include password if Redis is configured with requirepass
REDIS_URL=redis://:nexus@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=nexus

# -- Optional ---------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=

# -- SMS channel (optional) -------------------------------------------------
# Twilio via REST (no SDK). All three must be set to enable SMS; otherwise the
# SMS channel is a no-op.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# -- Push channel (optional) ------------------------------------------------
# FCM legacy HTTP API. Set FCM_SERVER_KEY to enable push; otherwise no-op.
FCM_SERVER_KEY=
# Optional FCM-style relay override (takes precedence over FCM_SERVER_KEY):
WEB_PUSH_ENDPOINT=
WEB_PUSH_KEY=
