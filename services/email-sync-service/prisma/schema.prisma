generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/email-sync-client"
}

datasource db {
  provider = "postgresql"
  url      = env("EMAIL_SYNC_DATABASE_URL")
}

model EmailConnection {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String   @unique
  provider     String
  email        String
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?
  syncEnabled  Boolean  @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  @@index([tenantId])
}

model EmailMessage {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  provider   String
  messageId  String   @unique
  threadId   String
  subject    String
  from       String
  to         String
  snippet    String
  body       String   @db.Text
  isRead     Boolean  @default(false)
  isInbound  Boolean
  sentAt     DateTime
  contactId  String?
  dealId     String?
  accountId  String?
  // RFC 5322 headers used to correlate replies into threads.
  rfcMessageId String?  // value of the message's own Message-ID header
  inReplyTo    String?  // value of the In-Reply-To header (parent Message-ID)
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([userId, threadId])
  @@index([contactId])
  @@index([dealId])
  @@index([tenantId, rfcMessageId])
}

model OutboxMessage {
  id             String   @id @default(cuid())
  tenantId       String
  topic          String
  payload        Json
  aggregateId    String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([status, createdAt])
  @@index([aggregateId])
}
