# -- Required ---------------------------------------------------------------
PORT=3022
NODE_ENV=development
PORTAL_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_portal
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=portal-service

# -- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -- Service-to-service (portal → finance/crm) ------------------------------
# Base URLs the portal proxies shared-link reads/decisions to, and the shared
# service token used for internal finance endpoints (mark-viewed).
FINANCE_SERVICE_URL=http://localhost:3003
CRM_SERVICE_URL=http://localhost:3001
DOCUMENT_SERVICE_URL=http://localhost:3016
INTERNAL_SERVICE_TOKEN=

# -- Optional ---------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=
