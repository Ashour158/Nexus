generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/accounts-client"
}

datasource db {
  provider = "postgresql"
  url      = env("ACCOUNTS_DATABASE_URL")
}

model Account {
  id                         String        @id @default(cuid())
  tenantId                   String
  ownerId                    String
  parentAccountId            String?
  code                       String?
  name                       String
  legalName                  String?
  tradeName                  String?
  website                    String?
  phone                      String?
  fax                        String?
  email                      String?
  industry                   String?
  subIndustry                String?
  type                       AccountType   @default(PROSPECT)
  tier                       AccountTier   @default(SMB)
  status                     AccountStatus @default(ACTIVE)
  lifecycleStage             String?
  annualRevenue              Decimal?      @db.Decimal(18, 2)
  employeeCount              Int?
  foundedYear                Int?
  country                    String?
  city                       String?
  address                    String?
  zipCode                    String?
  linkedInUrl                String?
  description                String?
  sicCode                    String?
  naicsCode                  String?
  taxId                      String?
  vatNumber                  String?
  commercialRegistrationNumber String?
  paymentTerms               String?
  creditLimit                Decimal?      @db.Decimal(18, 2)
  currency                   String?       @default("USD")
  priceBookId                String?
  territoryId                String?
  healthScore                Int?
  npsScore                   Int?
  riskLevel                  String?       @default("low")
  lastActivityAt             DateTime?
  billingAddressLine1        String?
  billingAddressLine2        String?
  billingCity                String?
  billingState               String?
  billingPostalCode          String?
  billingCountry             String?
  billingLatitude            Float?
  billingLongitude           Float?
  shippingAddressLine1       String?
  shippingAddressLine2       String?
  shippingCity               String?
  shippingState              String?
  shippingPostalCode         String?
  shippingCountry            String?
  shippingLatitude           Float?
  shippingLongitude          Float?
  shippingInstructions       String?
  sameAsBilling              Boolean       @default(false)
  customFields               Json          @default("{}")
  lat                        Float?
  lng                        Float?
  tags                       String[]
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  healthRecord               AccountHealthScore?
  dataQualityScore           Int?
  deletedAt                  DateTime?
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, ownerId])
  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([tenantId, parentAccountId])
  @@index([tenantId, code])
  @@unique([id, tenantId])
}

enum AccountType {
  PROSPECT
  CUSTOMER
  PARTNER
  COMPETITOR
  RESELLER
  OTHER
}

enum AccountTier {
  STRATEGIC
  ENTERPRISE
  MID_MARKET
  SMB
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  AT_RISK
  CHURNED
}

model AccountHealthScore {
  id               String   @id @default(uuid())
  tenantId         String
  accountId        String   @unique
  account          Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  score            Int      @default(0)
  riskLevel        String   @default("low")
  churnProbability Float    @default(0.0)
  signals          Json     @default("{}")
  lastActivityDays Int?
  openDealsCount   Int      @default(0)
  wonDealsCount    Int      @default(0)
  lostDealsCount   Int      @default(0)
  scoredAt         DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@index([tenantId])
  @@index([tenantId, riskLevel])
  @@unique([id, tenantId])
}

model OutboxMessage {
  id             String   @id @default(cuid())
  topic          String
  tenantId       String?
  key            String?
  payload        Json
  aggregateId    String?
  eventType      String?
  correlationId  String?
  headers        Json     @default("{}")
  status         String   @default("PENDING")
  error          String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([status, createdAt])
  @@index([aggregateId])
  @@index([tenantId])
}
