{
  "name": "@nexus/service-utils",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./db": {
      "import": "./dist/db.js",
      "types": "./dist/db.d.ts"
    },
    "./prisma-client": {
      "import": "./dist/prisma-client.js",
      "types": "./dist/prisma-client.d.ts"
    },
    "./tracing": {
      "import": "./dist/tracing.js",
      "types": "./dist/tracing.d.ts"
    },
    "./prisma-tenant": {
      "import": "./dist/prisma-tenant.js",
      "types": "./dist/prisma-tenant.d.ts"
    },
    "./request-context": {
      "import": "./dist/request-context.js",
      "types": "./dist/request-context.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.3.0",
    "@fastify/multipart": "^8.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/request-context": "^5.1.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@nexus/shared-types": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^1.25.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.1",
    "@opentelemetry/instrumentation-fastify": "^0.39.0",
    "@opentelemetry/instrumentation-http": "^0.52.1",
    "@opentelemetry/resources": "^1.25.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "@opentelemetry/sdk-trace-base": "^1.25.1",
    "@opentelemetry/semantic-conventions": "^1.25.1",
    "@sentry/node": "^10.50.0",
    "fastify": "^4.28.1",
    "graphql": "^16.9.0",
    "graphql-yoga": "^5.6.0",
    "@apollo/subgraph": "^2.8.0",
    "kafkajs": "^2.2.4",
    "pino": "^9.3.2",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "@types/node": "^20.14.9",
    "ioredis": "^5.4.1",
    "pino-pretty": "^11.2.2",
    "typescript": "^5.5.3",
    "vitest": "2.0.0"
  }
}
