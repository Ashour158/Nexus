# -- Required ---------------------------------------------------------------
PORT=3008
NODE_ENV=development
ANALYTICS_DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_analytics
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# -- Kafka ------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=analytics-service

# -- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -- Currency conversion (base-currency roll-ups) ---------------------------
# finance-service supplies the tenant base currency + active exchange rates.
# If unreachable, analytics falls back to 1:1 conversion (never blocks ingest).
FINANCE_SERVICE_URL=http://finance-service:3002
INTERNAL_SERVICE_TOKEN=
# Cache TTL for fetched rates (ms). Default 600000 = 10 min.
ANALYTICS_RATES_TTL_MS=600000
# Fallback base currency when finance has no base currency configured.
ANALYTICS_DEFAULT_BASE_CURRENCY=USD

# -- Optional ---------------------------------------------------------------
LOG_LEVEL=info
SENTRY_DSN=
