{
    "name": "@nexus/crm-service",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc --project tsconfig.build.json",
        "start": "node dist/index.js",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate deploy",
        "db:studio": "prisma studio"
    },
    "dependencies": {
        "@fastify/rate-limit": "^9.1.0",
        "@fastify/request-context": "^5.1.0",
        "@nexus/audit": "workspace:*",
        "@nexus/cache": "workspace:*",
        "@nexus/domain-core": "workspace:*",
        "@nexus/kafka": "workspace:*",
        "@nexus/outbox": "workspace:*",
        "@nexus/queue": "workspace:*",
        "@nexus/service-utils": "workspace:*",
        "@nexus/shared-types": "workspace:*",
        "@nexus/validation": "workspace:*",
        "@nexus/validation-gateway": "workspace:*",
        "@nexus/security": "workspace:*",
        "@prisma/client": "^5.15.0",
        "dotenv": "^16.4.5",
        "fastify": "^4.28.1",
        "prom-client": "^15.1.0",
        "zod": "^3.23.8",
        "@fastify/swagger": "^9.0.0",
        "@fastify/swagger-ui": "^5.0.0",
        "graphql": "^16.9.0",
        "graphql-yoga": "^5.6.0",
        "@apollo/subgraph": "^2.8.0"
    },
    "devDependencies": {
        "@types/node": "^20.14.9",
        "@types/supertest": "^7.2.0",
        "msw": "^2.3.1",
        "prisma": "^5.22.0",
        "supertest": "^7.2.2",
        "tsx": "^4.16.0",
        "typescript": "^5.5.3",
        "vitest": "^1.6.0"
    }
}
