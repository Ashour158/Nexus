generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/audit-consumer-client"
}

datasource db {
  provider = "postgresql"
  url      = env("AUDIT_DATABASE_URL")
}

model AuditLog {
  id            String   @id @default(cuid())
  tenantId      String
  actorId       String
  actorType     String   // user | service | system
  action        String   // e.g., "deal.created", "contact.updated"
  resource      String   // e.g., "deal", "contact"
  resourceId    String?
  changes       Json?    // { old: {}, new: {} }
  metadata      Json?    // { ipAddress, userAgent, requestId }
  timestamp     DateTime @default(now())
  correlationId String?

  @@index([tenantId, timestamp])
  @@index([tenantId, action])
  @@index([tenantId, resource, resourceId])
  @@index([actorId, timestamp])
}
